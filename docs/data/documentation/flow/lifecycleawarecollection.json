{"kind":"article","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Flow\/documentation\/Flow\/LifecycleAwareCollection"},"hierarchy":{"paths":[["doc:\/\/Flow\/documentation\/Flow"]]},"schemaVersion":{"patch":0,"major":0,"minor":3},"primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Overview","level":2,"anchor":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A flow that outlives its view wastes CPU, battery, and memory. A flow that stops too early drops events the user should see. FlowKit provides first-class lifecycle hooks for SwiftUI, UIKit, and AppKit so the right thing happens without manual cancellation calls."}]},{"type":"heading","text":"SwiftUI: @CollectedState","level":2,"anchor":"SwiftUI-CollectedState"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"FlowSwiftUI\/CollectedState"},{"type":"text","text":" is a "},{"type":"codeVoice","code":"DynamicProperty"},{"type":"text","text":" that integrates with SwiftUI’s view update cycle. SwiftUI calls "},{"type":"codeVoice","code":"update()"},{"type":"text","text":" when the view appears; "},{"type":"codeVoice","code":"@CollectedState"},{"type":"text","text":" starts collecting there. When the view is removed from the hierarchy, the underlying "},{"type":"codeVoice","code":"Task"},{"type":"text","text":" is cancelled."}]},{"type":"codeListing","syntax":"swift","code":["\/\/ The flow starts collecting when SessionBanner appears in the view hierarchy.","\/\/ It cancels automatically when the view disappears. No manual cleanup.","struct SessionBanner: View {","    @CollectedState(SessionManager.shared.sessionState)","    var session: SessionState = .signedOut","","    var body: some View {","        switch session {","        case .signedIn(let user):","            Label(user.displayName, systemImage: \"person.circle.fill\")","        case .signingIn:","            ProgressView(\"Signing in…\")","        case .signedOut:","            EmptyView()","        case .error(let message):","            Text(message).foregroundStyle(.red)","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"The initial value (","type":"text"},{"type":"codeVoice","code":".signedOut"},{"text":") is displayed synchronously on the first render; subsequent values from the ","type":"text"},{"type":"codeVoice","code":"StateFlow"},{"text":" drive re-renders.","type":"text"}]},{"type":"heading","text":"Animated updates","level":3,"anchor":"Animated-updates"},{"type":"paragraph","inlineContent":[{"text":"Pass an ","type":"text"},{"type":"codeVoice","code":"animation"},{"text":" parameter to animate state transitions:","type":"text"}]},{"type":"codeListing","syntax":"swift","code":["struct FeedView: View {","    \/\/ Posts slide in\/out with a spring animation when the feed updates.","    @CollectedState(feedViewModel.posts, animation: .spring(duration: 0.3))","    var posts: [Post] = []","","    var body: some View {","        List(posts) { PostRow(post: $0) }","    }","}"]},{"type":"heading","text":"Working with cold flows","level":3,"anchor":"Working-with-cold-flows"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"@CollectedState"},{"type":"text","text":" requires a "},{"type":"codeVoice","code":"StateFlow"},{"type":"text","text":", but you can convert any cold flow using "},{"type":"codeVoice","code":"asStateFlow"},{"type":"text","text":" in the view model:"}]},{"type":"codeListing","code":["@Observable","@MainActor","final class LocationViewModel {","    \/\/ Convert the cold location flow to a StateFlow once, here.","    \/\/ The sharing strategy keeps the GPS session alive for 5 seconds","    \/\/ after the map view disappears, in case of a brief navigation pop.","    let currentLocation: any StateFlow<CLLocation> = locationManager.updates","        .asStateFlow(","            initialValue: locationManager.lastLocation,","            strategy: .whileSubscribed(stopTimeout: .seconds(5))","        )","}","","struct MapView: View {","    let viewModel: LocationViewModel","","    @CollectedState(viewModel.currentLocation)","    var location: CLLocation = CLLocation(latitude: 0, longitude: 0)","","    var body: some View {","        Map(initialPosition: .region(MKCoordinateRegion(center: location.coordinate, ...)))","    }","}"],"syntax":"swift"},{"text":"UIKit: flowScope","level":2,"type":"heading","anchor":"UIKit-flowScope"},{"type":"paragraph","inlineContent":[{"code":"UIViewController.flowScope","type":"codeVoice"},{"text":" returns a ","type":"text"},{"code":"FlowCore\/FlowScope","type":"codeVoice"},{"text":" stored as an associated object. Because ","type":"text"},{"code":"OBJC_ASSOCIATION_RETAIN_NONATOMIC","type":"codeVoice"},{"text":" ties the scope’s lifetime to the view controller’s, the scope deallocates and cancels all tasks when the view controller is released.","type":"text"}]},{"type":"codeListing","code":["final class ChatViewController: UIViewController {","    private let viewModel: ChatViewModel","","    override func viewDidLoad() {","        super.viewDidLoad()","","        \/\/ Convenience method: collects a StateFlow on the main actor.","        collect(viewModel.messages) { [weak self] messages in","            self?.tableView.apply(messages)","        }","","        \/\/ For cold flows or more complex pipelines, use launch(in:) directly.","        viewModel.typingIndicators","            .throttle(for: .milliseconds(500))","            .onEach { [weak self] users in","                await MainActor.run { self?.updateTypingBanner(users) }","            }","            .launch(in: flowScope)","    }","    \/\/ viewController.flowScope.deinit fires when this VC is deallocated,","    \/\/ cancelling both tasks launched above.","}"],"syntax":"swift"},{"text":"When the view controller stays in memory but should stop","level":3,"type":"heading","anchor":"When-the-view-controller-stays-in-memory-but-should-stop"},{"type":"paragraph","inlineContent":[{"text":"If your architecture keeps view controllers in a stack and you want to stop collection when they leave the screen (not just when they deallocate), cancel and recreate the scope manually:","type":"text"}]},{"type":"codeListing","code":["override func viewWillDisappear(_ animated: Bool) {","    super.viewWillDisappear(animated)","    flowScope.cancel()","}","","override func viewWillAppear(_ animated: Bool) {","    super.viewWillAppear(animated)","    \/\/ Re-attach flows; flowScope.cancel() means a new scope is needed.","    \/\/ In practice, consider using a separate scope property for this pattern.","    startCollecting()","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"For most cases, letting deallocation handle it is simpler and correct.","type":"text"}]},{"text":"AppKit: NSViewController.flowScope and NSWindowController.flowScope","level":2,"type":"heading","anchor":"AppKit-NSViewControllerflowScope-and-NSWindowControllerflowScope"},{"type":"paragraph","inlineContent":[{"type":"text","text":"AppKit gets the same associated-object pattern. Both "},{"type":"codeVoice","code":"NSViewController"},{"type":"text","text":" and "},{"type":"codeVoice","code":"NSWindowController"},{"type":"text","text":" have a "},{"type":"codeVoice","code":"flowScope"},{"type":"text","text":" property:"}]},{"syntax":"swift","code":["final class ArticleWindowController: NSWindowController {","    private let viewModel: ArticleViewModel","","    override func windowDidLoad() {","        super.windowDidLoad()","","        \/\/ Collection is cancelled when the window controller deallocates.","        viewModel.articleState.asFlow()","            .onEach { [weak self] state in","                await MainActor.run { self?.render(state) }","            }","            .launch(in: flowScope)","    }","}","","final class SidebarViewController: NSViewController {","    private let navigationCoordinator: NavigationCoordinator","","    override func viewDidLoad() {","        super.viewDidLoad()","","        navigationCoordinator.currentSection.asFlow()","            .onEach { [weak self] section in","                await MainActor.run { self?.highlightSection(section) }","            }","            .launch(in: flowScope)","    }","}"],"type":"codeListing"},{"level":2,"type":"heading","anchor":"Manual-flowlaunchin-scope-for-custom-lifetimes","text":"Manual: flow.launch(in: scope) for custom lifetimes"},{"inlineContent":[{"type":"codeVoice","code":"launch(in:)"},{"type":"text","text":" works with any "},{"type":"codeVoice","code":"FlowCore\/FlowScope"},{"type":"text","text":" you own. This is the escape hatch for objects that don’t fit the standard UIKit\/AppKit patterns, such as custom coordinators, service objects with explicit start\/stop semantics, and long-running background processors:"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ A paginated feed that stops when the user navigates away from the section,","\/\/ not when the coordinator deallocates (which might be never).","actor FeedCoordinator {","    private var feedScope: FlowScope?","","    func startFeed(for section: Section) {","        feedScope?.cancel()","        let scope = FlowScope()","        feedScope = scope","","        feedRepository.paginatedFeed(section: section)","            .onEach { [weak self] page in await self?.appendPage(page) }","            .launch(in: scope)","    }","","    func stopFeed() {","        feedScope?.cancel()","        feedScope = nil","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The scope is a value you create, own, and cancel on your timeline."}],"type":"paragraph"},{"level":2,"type":"heading","anchor":"The-long-lived-singleton-pitfall","text":"The long-lived singleton pitfall"},{"inlineContent":[{"type":"text","text":"The most dangerous pattern is launching a flow in a scope that never cancels:"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ BAD: the singleton's scope lives for the app's entire lifetime.","class AnalyticsService {","    static let shared = AnalyticsService()","    private let scope = FlowScope()","","    init() {","        \/\/ This flow runs forever. Fine for truly app-lifetime work.","        \/\/ But if you add more flows here over time without auditing,","        \/\/ you accumulate tasks that never stop.","        userBehaviorFlow","            .onEach { event in await self.track(event) }","            .launch(in: scope)","    }","}"],"type":"codeListing"},{"inlineContent":[{"text":"This is fine for genuinely app-lifetime flows (telemetry, crash reporting). It becomes a problem when a “temporary” flow gets launched in the singleton and never cleaned up. Use explicit scope lifetimes, or cancel and recreate scopes for bounded work:","type":"text"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ GOOD: scoped to a user session, not the app lifetime.","class AnalyticsService {","    static let shared = AnalyticsService()","    private var sessionScope: FlowScope?","","    func startSession(for user: User) {","        sessionScope?.cancel()","        let scope = FlowScope()","        sessionScope = scope","","        userBehaviorFlow(for: user)","            .onEach { event in await self.track(event, user: user) }","            .launch(in: scope)","    }","","    func endSession() {","        sessionScope?.cancel()","        sessionScope = nil","    }","}"],"type":"codeListing"},{"level":2,"type":"heading","anchor":"Related-concepts","text":"Related concepts"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"identifier":"doc:\/\/Flow\/documentation\/Flow\/CancellationSemantics","type":"reference","isActive":true},{"text":": how cancellation propagates from scope through task to flow body","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"identifier":"doc:\/\/Flow\/documentation\/Flow\/HotVsColdStreams","type":"reference"},{"text":": why ","type":"text"},{"code":"whileSubscribed","type":"codeVoice"},{"text":" strategy pairs well with lifecycle-aware collection","type":"text"}]}]}]}]}],"metadata":{"title":"Lifecycle-Aware Collection","role":"article","modules":[{"name":"Flow"}],"roleHeading":"Article"},"seeAlsoSections":[{"title":"Getting Started","generated":true,"anchor":"Getting-Started","identifiers":["doc:\/\/Flow\/documentation\/Flow\/HotVsColdStreams","doc:\/\/Flow\/documentation\/Flow\/FlowVsThrowingFlow"]}],"variants":[{"paths":["\/documentation\/flow\/lifecycleawarecollection"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"text":"Bind flow lifetimes to UI objects so collection starts when a view appears and stops automatically when it disappears.","type":"text"}],"sections":[],"references":{"doc://Flow/documentation/Flow/CancellationSemantics":{"url":"\/documentation\/flow\/cancellationsemantics","abstract":[{"text":"How cancellation flows from ","type":"text"},{"code":"FlowCore\/FlowScope","type":"codeVoice"},{"text":" through Swift Tasks into flow bodies, and what goes wrong when you bypass the chain.","type":"text"}],"type":"topic","identifier":"doc:\/\/Flow\/documentation\/Flow\/CancellationSemantics","role":"article","kind":"article","title":"Cancellation Semantics"},"doc://Flow/documentation/Flow":{"kind":"symbol","type":"topic","url":"\/documentation\/flow","abstract":[{"text":"Kotlin Flow semantics in Swift, built on Swift 6.3 strict concurrency.","type":"text"}],"identifier":"doc:\/\/Flow\/documentation\/Flow","role":"collection","title":"Flow"},"doc://Flow/documentation/Flow/HotVsColdStreams":{"title":"Hot vs Cold Streams","role":"article","url":"\/documentation\/flow\/hotvscoldstreams","abstract":[{"type":"text","text":"Cold streams run once per collector. Hot streams share a single execution across all collectors. Choosing the right kind prevents duplicate network requests, dropped events, and stale state."}],"identifier":"doc:\/\/Flow\/documentation\/Flow\/HotVsColdStreams","type":"topic","kind":"article"},"doc://Flow/documentation/Flow/FlowVsThrowingFlow":{"abstract":[{"text":"A decision guide for choosing between ","type":"text"},{"code":"FlowCore\/Flow","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"FlowCore\/ThrowingFlow","type":"codeVoice"},{"text":", and how to convert between them when your pipeline crosses the boundary.","type":"text"}],"identifier":"doc:\/\/Flow\/documentation\/Flow\/FlowVsThrowingFlow","url":"\/documentation\/flow\/flowvsthrowingflow","title":"Flow vs ThrowingFlow","role":"article","type":"topic","kind":"article"}}}