"inlineContent":[{"type":"strong","inlineContent":[{"text":"FlowKit:","type":"text"}]}]},{"type":"codeListing","syntax":"swift","code":["@Observable","@MainActor","final class SearchViewModel {","    private let repo: ProductRepository","    private let query = MutableStateFlow(\"\")","","    let results: any StateFlow<SearchState>","","    init(repo: ProductRepository) {","        self.repo = repo","        results = query.asFlow()","            .debounce(for: .milliseconds(300))","            .removeDuplicates()","            .filter { !$0.isEmpty }","            .flatMapLatest { q -> ThrowingFlow<[Product]> in repo.search(q) }","            .map { SearchState.loaded($0) }","            .catch { _, collector in await collector.emit(.error(\"Search failed\")) }","            .asStateFlow(initialValue: .idle, strategy: .whileSubscribed(stopTimeout: .seconds(5)))","    }","","    func update(query text: String) async { await query.send(text) }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Key differences: "},{"type":"codeVoice","code":"flatMapLatest"},{"type":"text","text":" over a "},{"type":"codeVoice","code":"ThrowingFlow"},{"type":"text","text":" requires an explicit return type annotation in Swift 6; "},{"type":"codeVoice","code":"catch"},{"type":"text","text":" receives the collector explicitly rather than using "},{"type":"codeVoice","code":"emit"},{"type":"text","text":" via "},{"type":"codeVoice","code":"this"},{"type":"text","text":"; "},{"type":"codeVoice","code":"stateIn"},{"type":"text","text":" becomes "},{"type":"codeVoice","code":"asStateFlow"},{"type":"text","text":" with a separate "},{"type":"codeVoice","code":"FlowScope"},{"type":"text","text":"."}]},{"type":"thematicBreak"},{"level":3,"type":"heading","text":"Session state sharing","anchor":"Session-state-sharing"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Kotlin:","type":"text"}]}]},{"type":"codeListing","syntax":"kotlin","code":["class SessionManager(private val authService: AuthService) {","    private val _state = MutableStateFlow<SessionState>(SessionState.SignedOut)","","    val sessionState: StateFlow<SessionState> = _state.asStateFlow()","","    init {","        authService.events","            .onEach { event ->","                _state.value = when (event) {","                    is AuthEvent.SignedIn -> SessionState.SignedIn(event.user)","                    is AuthEvent.SignedOut -> SessionState.SignedOut","                    is AuthEvent.Error -> SessionState.Error(event.message)","                }","            }","            .launchIn(GlobalScope) \/\/ simplified for illustration","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"FlowKit:","type":"text"}]}]},{"type":"codeListing","syntax":"swift","code":["actor SessionManager {","    private let _state = MutableStateFlow<SessionState>(.signedOut)","    var sessionState: any StateFlow<SessionState> { _state }","","    init(authService: AuthService) {","        Task {","            await authService.events.collect { event in","                switch event {","                case .signedIn(let user): await _state.send(.signedIn(user))","                case .signedOut: await _state.send(.signedOut)","                case .error(let message): await _state.send(.error(message))","                }","            }","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Key differences: "},{"type":"codeVoice","code":"actor"},{"type":"text","text":" replaces "},{"type":"codeVoice","code":"@HiltViewModel"},{"type":"text","text":"\/"},{"type":"codeVoice","code":"class"},{"type":"text","text":"; "},{"type":"codeVoice","code":"_state.value = "},{"type":"text","text":" becomes "},{"type":"codeVoice","code":"await _state.send()"},{"type":"text","text":"; "},{"type":"codeVoice","code":"launchIn"},{"type":"text","text":" becomes "},{"type":"codeVoice","code":"Task { }"},{"type":"text","text":" or "},{"type":"codeVoice","code":"launch(in: scope)"},{"type":"text","text":" for proper cancellation."}]},{"type":"thematicBreak"},{"level":3,"type":"heading","text":"Form validation with combine","anchor":"Form-validation-with-combine"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Kotlin:","type":"text"}]}]},{"type":"codeListing","syntax":"kotlin","code":["val isFormValid: StateFlow<Boolean> = combine(username, password, email) { u, p, e ->","    u.length >= 3 && p.length >= 8 && e.contains('@')","}.stateIn(viewModelScope, SharingStarted.Eagerly, false)"]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"FlowKit:","type":"text"}]}]},{"type":"codeListing","syntax":"swift","code":["\/\/ FlowKit uses combineLatest chaining (no variadic combine yet):","let isFormValid: any StateFlow<Bool> = username","    .combineLatest(password) { u, p in (u, p) }","    .combineLatest(email) { (u, p), e in","        u.count >= 3 && p.count >= 8 && e.contains(\"@\")","    }","    .asStateFlow(initialValue: false, strategy: .eager)"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Key difference: FlowKit’s "},{"type":"codeVoice","code":"combineLatest"},{"type":"text","text":" is binary (pairs two flows); chain multiple calls to combine three or more. A variadic "},{"type":"codeVoice","code":"combine"},{"type":"text","text":" operator is planned for a future release."}]},{"level":2,"type":"heading","text":"Conceptual differences","anchor":"Conceptual-differences"},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"No ","type":"text"},{"code":"CoroutineScope","type":"codeVoice"},{"text":" parameter on operators.","type":"text"}]},{"type":"text","text":" In Kotlin, "},{"type":"codeVoice","code":"stateIn"},{"type":"text","text":" and "},{"type":"codeVoice","code":"shareIn"},{"type":"text","text":" take an explicit "},{"type":"codeVoice","code":"CoroutineScope"},{"type":"text","text":" to anchor the upstream collection. In FlowKit, "},{"type":"codeVoice","code":"asStateFlow"},{"type":"text","text":" and "},{"type":"codeVoice","code":"asSharedFlow"},{"type":"text","text":" use an internal "},{"type":"codeVoice","code":"Task"},{"type":"text","text":" and rely on the "},{"type":"codeVoice","code":"SharingStrategy"},{"type":"text","text":" to control upstream lifetime. Pass a "},{"type":"codeVoice","code":"FlowScope"},{"type":"text","text":" to "},{"type":"codeVoice","code":"launch(in:)"},{"type":"text","text":" when you need explicit scope control over the collection site."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"code":"flow { }","type":"codeVoice"},{"text":" body receives a ","type":"text"},{"code":"Collector","type":"codeVoice"},{"text":", not ","type":"text"},{"code":"this","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"text","text":" In Kotlin, "},{"type":"codeVoice","code":"emit"},{"type":"text","text":" is called directly in the "},{"type":"codeVoice","code":"flow { }"},{"type":"text","text":" block because the block is a "},{"type":"codeVoice","code":"FlowCollector"},{"type":"text","text":" receiver. In FlowKit, the body closure receives an explicit "},{"type":"codeVoice","code":"Collector<Element>"},{"type":"text","text":" parameter. Use "},{"type":"codeVoice","code":"await collector.emit(value)"},{"type":"text","text":" or the trailing-closure shorthand "},{"type":"codeVoice","code":"$0"},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"Errors require ","type":"text"},{"code":"ThrowingFlow","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"text","text":" Kotlin "},{"type":"codeVoice","code":"Flow"},{"type":"text","text":" can carry errors (the flow itself is always non-throwing; errors surface via "},{"type":"codeVoice","code":"catch"},{"type":"text","text":"). FlowKit uses separate "},{"type":"codeVoice","code":"Flow"},{"type":"text","text":" and "},{"type":"codeVoice","code":"ThrowingFlow"},{"type":"text","text":" types. The compiler enforces which is which at every call site."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"text":"No ","type":"text"},{"code":"StateFlow.value","type":"codeVoice"},{"text":" direct set.","type":"text"}]},{"type":"text","text":" Kotlin allows "},{"type":"codeVoice","code":"_state.value = newValue"},{"type":"text","text":" synchronously. FlowKit requires "},{"type":"codeVoice","code":"await _state.send(newValue)"},{"type":"text","text":" because "},{"type":"codeVoice","code":"MutableStateFlow"},{"type":"text","text":" is an "},{"type":"codeVoice","code":"actor"},{"type":"text","text":"."}]},{"level":2,"type":"heading","text":"Related concepts","anchor":"Related-concepts"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/Flow\/documentation\/Flow\/HotVsColdStreams","isActive":true},{"type":"text","text":": cold\/hot distinction and sharing strategies"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/Flow\/documentation\/Flow\/FlowVsThrowingFlow","isActive":true},{"type":"text","text":": when to use each stream type"}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"reference","identifier":"doc:\/\/Flow\/documentation\/Flow\/CancellationSemantics","isActive":true},{"type":"text","text":": Swift structured concurrency vs Kotlin coroutine cancellation"}],"type":"paragraph"}]}]}],"kind":"content"}],"references":{"doc://Flow/documentation/Flow/HotVsColdStreams":{"role":"article","identifier":"doc:\/\/Flow\/documentation\/Flow\/HotVsColdStreams","abstract":[{"type":"text","text":"Cold streams run once per collector. Hot streams share a single execution across all collectors. Choosing the right kind prevents duplicate network requests, dropped events, and stale state."}],"type":"topic","kind":"article","title":"Hot vs Cold Streams","url":"\/documentation\/flow\/hotvscoldstreams"},"doc://Flow/documentation/Flow/FlowVsThrowingFlow":{"role":"article","identifier":"doc:\/\/Flow\/documentation\/Flow\/FlowVsThrowingFlow","abstract":[{"type":"text","text":"A decision guide for choosing between "},{"type":"codeVoice","code":"FlowCore\/Flow"},{"type":"text","text":" and "},{"type":"codeVoice","code":"FlowCore\/ThrowingFlow"},{"type":"text","text":", and how to convert between them when your pipeline crosses the boundary."}],"type":"topic","kind":"article","title":"Flow vs ThrowingFlow","url":"\/documentation\/flow\/flowvsthrowingflow"},"doc://Flow/documentation/Flow":{"role":"collection","identifier":"doc:\/\/Flow\/documentation\/Flow","abstract":[{"type":"text","text":"Kotlin Flow semantics in Swift, built on Swift 6.3 strict concurrency."}],"type":"topic","kind":"symbol","title":"Flow","url":"\/documentation\/flow"},"doc://Flow/documentation/Flow/CancellationSemantics":{"role":"article","identifier":"doc:\/\/Flow\/documentation\/Flow\/CancellationSemantics","abstract":[{"type":"text","text":"How cancellation flows from "},{"type":"codeVoice","code":"FlowCore\/FlowScope"},{"type":"text","text":" through Swift Tasks into flow bodies, and what goes wrong when you bypass the chain."}],"type":"topic","kind":"article","title":"Cancellation Semantics","url":"\/documentation\/flow\/cancellationsemantics"}}}