in repo.search(q) }","            .map { SearchState.loaded($0) }","            .catch { _, collector in await collector.emit(.error(\"Search failed\")) }","            .asStateFlow(initialValue: .idle, strategy: .whileSubscribed(stopTimeout: .seconds(5)))","    }","","    func update(query text: String) async { await query.send(text) }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Key differences: "},{"type":"codeVoice","code":"flatMapLatest"},{"type":"text","text":" over a "},{"type":"codeVoice","code":"ThrowingFlow"},{"type":"text","text":" requires an explicit return type annotation in Swift 6; "},{"type":"codeVoice","code":"catch"},{"type":"text","text":" receives the collector explicitly rather than using "},{"type":"codeVoice","code":"emit"},{"type":"text","text":" via "},{"type":"codeVoice","code":"this"},{"type":"text","text":"; "},{"type":"codeVoice","code":"stateIn"},{"type":"text","text":" becomes "},{"type":"codeVoice","code":"asStateFlow"},{"type":"text","text":" with a separate "},{"type":"codeVoice","code":"FlowScope"},{"type":"text","text":"."}]},{"type":"thematicBreak"},{"level":3,"type":"heading","anchor":"Session-state-sharing","text":"Session state sharing"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"type":"text","text":"Kotlin:"}],"type":"strong"}]},{"type":"codeListing","syntax":"kotlin","code":["class SessionManager(private val authService: AuthService) {","    private val _state = MutableStateFlow<SessionState>(SessionState.SignedOut)","","    val sessionState: StateFlow<SessionState> = _state.asStateFlow()","","    init {","        authService.events","            .onEach { event ->","                _state.value = when (event) {","                    is AuthEvent.SignedIn -> SessionState.SignedIn(event.user)","                    is AuthEvent.SignedOut -> SessionState.SignedOut","                    is AuthEvent.Error -> SessionState.Error(event.message)","                }","            }","            .launchIn(GlobalScope) \/\/ simplified for illustration","    }","}"]},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"FlowKit:","type":"text"}],"type":"strong"}]},{"type":"codeListing","syntax":"swift","code":["actor SessionManager {","    private let _state = MutableStateFlow<SessionState>(.signedOut)","    var sessionState: any StateFlow<SessionState> { _state }","","    init(authService: AuthService) {","        Task {","            await authService.events.collect { event in","                switch event {","                case .signedIn(let user): await _state.send(.signedIn(user))","                case .signedOut: await _state.send(.signedOut)","                case .error(let message): await _state.send(.error(message))","                }","            }","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Key differences: "},{"type":"codeVoice","code":"actor"},{"type":"text","text":" replaces "},{"type":"codeVoice","code":"@HiltViewModel"},{"type":"text","text":"\/"},{"type":"codeVoice","code":"class"},{"type":"text","text":"; "},{"type":"codeVoice","code":"_state.value = "},{"type":"text","text":" becomes "},{"type":"codeVoice","code":"await _state.send()"},{"type":"text","text":"; "},{"type":"codeVoice","code":"launchIn"},{"type":"text","text":" becomes "},{"type":"codeVoice","code":"Task { }"},{"type":"text","text":" or "},{"type":"codeVoice","code":"launch(in: scope)"},{"type":"text","text":" for proper cancellation."}]},{"type":"thematicBreak"},{"text":"Form validation with combine","level":3,"type":"heading","anchor":"Form-validation-with-combine"},{"inlineContent":[{"inlineContent":[{"text":"Kotlin:","type":"text"}],"type":"strong"}],"type":"paragraph"},{"code":["val isFormValid: StateFlow<Boolean> = combine(username, password, email) { u, p, e ->","    u.length >= 3 && p.length >= 8 && e.contains('@')","}.stateIn(viewModelScope, SharingStarted.Eagerly, false)"],"type":"codeListing","syntax":"kotlin"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"FlowKit:"}]}],"type":"paragraph"},{"code":["\/\/ FlowKit uses combineLatest chaining (no variadic combine yet):","let isFormValid: any StateFlow<Bool> = username","    .combineLatest(password) { u, p in (u, p) }","    .combineLatest(email) { (u, p), e in","        u.count >= 3 && p.count >= 8 && e.contains(\"@\")","    }","    .asStateFlow(initialValue: false, strategy: .eager)"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"Key difference: FlowKit’s "},{"code":"combineLatest","type":"codeVoice"},{"type":"text","text":" is binary (pairs two flows); chain multiple calls to combine three or more. A variadic "},{"code":"combine","type":"codeVoice"},{"type":"text","text":" operator is planned for a future release."}],"type":"paragraph"},{"text":"Conceptual differences","level":2,"type":"heading","anchor":"Conceptual-differences"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"No "},{"type":"codeVoice","code":"CoroutineScope"},{"type":"text","text":" parameter on operators."}],"type":"strong"},{"type":"text","text":" In Kotlin, "},{"type":"codeVoice","code":"stateIn"},{"type":"text","text":" and "},{"type":"codeVoice","code":"shareIn"},{"type":"text","text":" take an explicit "},{"type":"codeVoice","code":"CoroutineScope"},{"type":"text","text":" to anchor the upstream collection. In FlowKit, "},{"type":"codeVoice","code":"asStateFlow"},{"type":"text","text":" and "},{"type":"codeVoice","code":"asSharedFlow"},{"type":"text","text":" use an internal "},{"type":"codeVoice","code":"Task"},{"type":"text","text":" and rely on the "},{"type":"codeVoice","code":"SharingStrategy"},{"type":"text","text":" to control upstream lifetime. Pass a "},{"type":"codeVoice","code":"FlowScope"},{"type":"text","text":" to "},{"type":"codeVoice","code":"launch(in:)"},{"type":"text","text":" when you need explicit scope control over the collection site."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"code":"flow { }","type":"codeVoice"},{"text":" body receives a ","type":"text"},{"code":"Collector","type":"codeVoice"},{"text":", not ","type":"text"},{"code":"this","type":"codeVoice"},{"text":".","type":"text"}]},{"text":" In Kotlin, ","type":"text"},{"type":"codeVoice","code":"emit"},{"text":" is called directly in the ","type":"text"},{"type":"codeVoice","code":"flow { }"},{"text":" block because the block is a ","type":"text"},{"code":"FlowCollector","type":"codeVoice"},{"text":" receiver. In FlowKit, the body closure receives an explicit ","type":"text"},{"code":"Collector<Element>","type":"codeVoice"},{"text":" parameter. Use ","type":"text"},{"code":"await collector.emit(value)","type":"codeVoice"},{"text":" or the trailing-closure shorthand ","type":"text"},{"code":"$0","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"Errors require ","type":"text"},{"code":"ThrowingFlow","type":"codeVoice"},{"text":".","type":"text"}],"type":"strong"},{"type":"text","text":" Kotlin "},{"code":"Flow","type":"codeVoice"},{"type":"text","text":" can carry errors (the flow itself is always non-throwing; errors surface via "},{"code":"catch","type":"codeVoice"},{"type":"text","text":"). FlowKit uses separate "},{"code":"Flow","type":"codeVoice"},{"type":"text","text":" and "},{"code":"ThrowingFlow","type":"codeVoice"},{"type":"text","text":" types. The compiler enforces which is which at every call site."}]},{"type":"paragraph","inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"No "},{"type":"codeVoice","code":"StateFlow.value"},{"type":"text","text":" direct set."}]},{"type":"text","text":" Kotlin allows "},{"type":"codeVoice","code":"_state.value = newValue"},{"type":"text","text":" synchronously. FlowKit requires "},{"type":"codeVoice","code":"await _state.send(newValue)"},{"type":"text","text":" because "},{"t