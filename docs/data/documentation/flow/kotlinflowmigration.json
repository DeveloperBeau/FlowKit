","    private let repo: ProductRepository","    private let query = MutableStateFlow(\"\")","","    let results: any StateFlow<SearchState>","","    init(repo: ProductRepository) {","        self.repo = repo","        results = query.asFlow()","            .debounce(for: .milliseconds(300))","            .removeDuplicates()","            .filter { !$0.isEmpty }","            .flatMapLatest { q -> ThrowingFlow<[Product]> in repo.search(q) }","            .map { SearchState.loaded($0) }","            .catch { _, collector in await collector.emit(.error(\"Search failed\")) }","            .asStateFlow(initialValue: .idle, strategy: .whileSubscribed(stopTimeout: .seconds(5)))","    }","","    func update(query text: String) async { await query.send(text) }","}"]},{"inlineContent":[{"type":"text","text":"Key differences: "},{"code":"flatMapLatest","type":"codeVoice"},{"text":" over a ","type":"text"},{"code":"ThrowingFlow","type":"codeVoice"},{"text":" requires an explicit return type annotation in Swift 6; ","type":"text"},{"code":"catch","type":"codeVoice"},{"text":" receives the collector explicitly rather than using ","type":"text"},{"code":"emit","type":"codeVoice"},{"text":" via ","type":"text"},{"code":"this","type":"codeVoice"},{"text":"; ","type":"text"},{"code":"stateIn","type":"codeVoice"},{"text":" becomes ","type":"text"},{"code":"asStateFlow","type":"codeVoice"},{"text":" with a separate ","type":"text"},{"code":"FlowScope","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"thematicBreak"},{"text":"Session state sharing","type":"heading","level":3,"anchor":"Session-state-sharing"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"Kotlin:"}],"type":"strong"}],"type":"paragraph"},{"syntax":"kotlin","type":"codeListing","code":["class SessionManager(private val authService: AuthService) {","    private val _state = MutableStateFlow<SessionState>(SessionState.SignedOut)","","    val sessionState: StateFlow<SessionState> = _state.asStateFlow()","","    init {","        authService.events","            .onEach { event ->","                _state.value = when (event) {","                    is AuthEvent.SignedIn -> SessionState.SignedIn(event.user)","                    is AuthEvent.SignedOut -> SessionState.SignedOut","                    is AuthEvent.Error -> SessionState.Error(event.message)","                }","            }","            .launchIn(GlobalScope) \/\/ simplified for illustration","    }","}"]},{"inlineContent":[{"inlineContent":[{"text":"FlowKit:","type":"text"}],"type":"strong"}],"type":"paragraph"},{"syntax":"swift","type":"codeListing","code":["actor SessionManager {","    private let _state = MutableStateFlow<SessionState>(.signedOut)","    var sessionState: any StateFlow<SessionState> { _state }","","    init(authService: AuthService) {","        Task {","            await authService.events.collect { event in","                switch event {","                case .signedIn(let user): await _state.send(.signedIn(user))","                case .signedOut: await _state.send(.signedOut)","                case .error(let message): await _state.send(.error(message))","                }","            }","        }","    }","}"]},{"inlineContent":[{"text":"Key differences: ","type":"text"},{"type":"codeVoice","code":"actor"},{"text":" replaces ","type":"text"},{"type":"codeVoice","code":"@HiltViewModel"},{"text":"\/","type":"text"},{"type":"codeVoice","code":"class"},{"text":"; ","type":"text"},{"type":"codeVoice","code":"_state.value = "},{"text":" becomes ","type":"text"},{"type":"codeVoice","code":"await _state.send()"},{"text":"; ","type":"text"},{"type":"codeVoice","code":"launchIn"},{"text":" becomes ","type":"text"},{"type":"codeVoice","code":"Task { }"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"launch(in: scope)"},{"text":" for proper cancellation.","type":"text"}],"type":"paragraph"},{"type":"thematicBreak"},{"text":"Form validation with combine",