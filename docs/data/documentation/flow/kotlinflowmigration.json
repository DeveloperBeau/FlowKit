 .whileSubscribed(stopTimeout: .seconds(5)))","    }","","    func update(query text: String) async { await query.send(text) }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Key differences: "},{"type":"codeVoice","code":"flatMapLatest"},{"type":"text","text":" over a "},{"type":"codeVoice","code":"ThrowingFlow"},{"type":"text","text":" requires an explicit return type annotation in Swift 6; "},{"type":"codeVoice","code":"catch"},{"type":"text","text":" receives the collector explicitly rather than using "},{"type":"codeVoice","code":"emit"},{"type":"text","text":" via "},{"type":"codeVoice","code":"this"},{"type":"text","text":"; "},{"type":"codeVoice","code":"stateIn"},{"type":"text","text":" becomes "},{"type":"codeVoice","code":"asStateFlow"},{"type":"text","text":" with a separate "},{"type":"codeVoice","code":"FlowScope"},{"type":"text","text":"."}],"type":"paragraph"},{"type":"thematicBreak"},{"text":"Session state sharing","anchor":"Session-state-sharing","type":"heading","level":3},{"inlineContent":[{"type":"strong","inlineContent":[{"text":"Kotlin:","type":"text"}]}],"type":"paragraph"},{"syntax":"kotlin","code":["class SessionManager(private val authService: AuthService) {","    private val _state = MutableStateFlow<SessionState>(SessionState.SignedOut)","","    val sessionState: StateFlow<SessionState> = _state.asStateFlow()","","    init {","        authService.events","            .onEach { event ->","                _state.value = when (event) {","                    is AuthEvent.SignedIn -> SessionState.SignedIn(event.user)","                    is AuthEvent.SignedOut -> SessionState.SignedOut","                    is AuthEvent.Error -> SessionState.Error(event.message)","                }","            }","            .launchIn(GlobalScope) \/\/ simplified for illustration","    }","}"],"type":"codeListing"},{"inlineContent":[{"inlineContent":[{"type":"text","text":"FlowKit:"}],"type":"strong"}],"type":"paragraph"},{"syntax":"swift","code":["actor SessionManager {","    private let _state = MutableStateFlow<SessionState>(.signedOut)","    var sessionState: any StateFlow<SessionState> { _state }","","    init(authService: AuthService) {","        Task {","            await authService.events.collect { event in","                switch event {","                case .signedIn(let user): await _state.send(.signedIn(user))","                case .signedOut: await _state.send(.signedOut)","                case .error(let message): await _state.send(.error(message))","                }","            }","        }","    }","}"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Key differences: "},{"code":"actor","type":"codeVoice"},{"type":"text","text":" replaces "},{"code":"@HiltViewModel","type":"codeVoice"},{"type":"text","text":"\/"},{"code":"class","type":"codeVoice"},{"type":"text","text":"; "},{"code":"_state.value = ","type":"codeVoice"},{"type":"text","text":" becomes "},{"code":"await _state.send()","type":"codeVoice"},{"type":"text","text":"; "},{"code":"launchIn","type":"codeVoice"},{"type":"text","text":" becomes "},{"code":"Task { }","type":"codeVoice"},{"type":"text","text":" or "},{"code":"launch(in: scope)","type":"codeVoice"},{"type":"text","text":" for proper cancellation."}],"type":"paragraph"},{"type":"thematicBreak"},{"text":"Form validation with combine","anchor":"Form-validation-with-combine","type":"heading","level":3},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"Kotlin:"}]}],"type":"paragraph"},{"syntax":"kotlin","code":["val isFormValid: StateFlow<Boolean> = combine(username, password, email) { u, p, e ->","    u.length >= 3 && p.length >= 8 && e.contains('@')","}.stateIn(viewModelScope, SharingStarted.Eagerly, false)"],"type":"codeListing"},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"FlowKit:"}]}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ FlowKit uses combineLatest chaining (no variadic combine yet):","let isFormValid: any StateFlow<Bool> = username","    .combineLatest(password) { u, p in (u, p) }","    .combineLatest(email) { (u, p), e in","        u.count >= 3 && p.count >= 8 && e.contains(\"@\")","    }","    .asStateFlow(initialValue: false, strategy: .eager)"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"Key difference: FlowKit’s "},{"code":"combineLatest","type":"codeVoice"},{"type":"text","text":" is binary (pairs two flows); chain multiple calls to combine three or more. A variadic "},{"code":"combine","type":"codeVoice"},{"type":"text","text":" operator is planned for a future release."}],"type":"paragraph"},{"text":"Conceptual differences","anchor":"Conceptual-differences","type":"heading","level":2},{"inlineContent":[{"type":"strong","inlineContent":[{"type":"text","text":"No "},{"type":"codeVoice","code":"CoroutineScope"},{"type":"text","text":" parameter on operators."}]},{"type":"text","text":" In Kotlin, "},{"code":"stateIn","type":"codeVoice"},{"type":"text","text":" and "},{"code":"shareIn","type":"codeVoice"},{"type":"text","text":" take an explicit "},{"code":"CoroutineScope","type":"codeVoice"},{"type":"text","text":" to anchor the upstream collection. In FlowKit, "},{"code":"asStateFlow","type":"codeVoice"},{"type":"text","text":" and "},{"code":"asSharedFlow","type":"codeVoice"},{"type":"text","text":" use an internal "},{"code":"Task","type":"codeVoice"},{"type":"text","text":" and rely on the "},{"code":"SharingStrategy","type":"codeVoice"},{"type":"text","text":" to control upstream lifetime. Pass a "},{"code":"FlowScope","type":"codeVoice"},{"type":"text","text":" to "},{"code":"launch(in:)","type":"codeVoice"},{"type":"text","text":" when you need explicit scope control over the collection site."}],"type":"paragraph"},{"inlineContent":[{"type":"strong","inlineContent":[{"code":"flow { }","type":"codeVoice"},{"text":" body receives a ","type":"text"},{"code":"Collector","type":"codeVoice"},{"text":", not ","type":"text"},{"code":"this","type":"codeVoice"},{"text":".","type":"text"}]},{"type":"text","text":" In Kotlin, "},{"type":"codeVoice","code":"emit"},{"type":"text","text":" is called directly in the "},{"type":"codeVoice","code":"flow { }"},{"type":"text","text":" block because the block is a "},{"type":"codeVoice","code":"FlowCollector"},{"type":"text","text":" receiver. In FlowKit, the body closure receives an explicit "},{"type":"codeVoice","code":"Collector<Element>"},{"text":" parameter. Use ","type":"text"},{"code":"await collector.emit(value)","type":"codeVoice"},{"text":" or the trailing-closure shorthand ","type":"text"},{"code":"$0","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"inlineContent":[{"inlineContent":[{"text":"Errors require ","type":"text"},{"type":"codeVoice","code":"ThrowingFlow"},{"text":".","type":"text"}],"type":"strong"},{"text":" Kotlin ","type":"text"},{"code":"Flow","type":"codeVoice"},{"text":" can carry errors (the flow itself is always non-throwing; errors surface via ","type":"text"},{"code":"catch","type":"codeVoice"},{"text":"). FlowKit uses separate ","type":"text"},{"code":"Flow","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"ThrowingFlow","type":"codeVoice"},{"text":" types. The compiler enforces which is which at every call site.","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"inlineContent":[{"text":"No ","type":"text"},{"code":"StateFlow.value","type":"codeVoice"},{"text":" direct set.","type":"text"}],"type":"strong"},{"type":"text","text":" Kotlin allows "},{"code":"_state.value = newValue","type":"codeVoice"},{"type":"text","text":" synchronously. FlowKit requires "},{"code":"await _state.send(newValue)","type":"codeVoice"},{"type":"text","text":" because "},{"code":"MutableStateFlow","type":"codeVoice"},{"type":"text","text":" is an "},{"code":"actor","type":"codeVoice"},{"type":"text","text":"."}]},{"text":"Related concepts","anchor":"Related-conc