{"hierarchy":{"paths":[["doc:\/\/Flow\/documentation\/Flow"]]},"metadata":{"modules":[{"name":"Flow"}],"title":"Flow vs ThrowingFlow","roleHeading":"Article","role":"article"},"schemaVersion":{"patch":0,"major":0,"minor":3},"seeAlsoSections":[{"identifiers":["doc:\/\/Flow\/documentation\/Flow\/HotVsColdStreams","doc:\/\/Flow\/documentation\/Flow\/LifecycleAwareCollection"],"anchor":"Getting-Started","generated":true,"title":"Getting Started"}],"primaryContentSections":[{"content":[{"anchor":"Overview","type":"heading","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"FlowKit uses two distinct stream types rather than a single "},{"code":"Result","type":"codeVoice"},{"type":"text","text":"-emitting type. The distinction is load-bearing: the Swift compiler enforces it at call sites, operators are defined separately on each, and conversion between them is always explicit. This catches a whole class of bugs, such as silent error swallowing and incorrect error propagation, at compile time rather than runtime."}]},{"anchor":"The-decision-rule","type":"heading","level":2,"text":"The decision rule"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Ask one question: "},{"type":"strong","inlineContent":[{"type":"text","text":"can this source ever fail with an error?"}]}]},{"rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Source"}]}],[{"type":"paragraph","inlineContent":[{"text":"Type","type":"text"}]}],[{"type":"paragraph","inlineContent":[{"text":"Reason","type":"text"}]}]],[[{"type":"paragraph","inlineContent":[{"text":"Keyboard input from a ","type":"text"},{"type":"codeVoice","code":"UITextField"}]}],[{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":"Flow<String>"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Text field observation cannot throw"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"GPS coordinates from "},{"code":"CLLocationManager","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"code":"Flow<CLLocation>","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Sensor callbacks are non-throwing"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Timer ticks"}]}],[{"type":"paragraph","inlineContent":[{"code":"Flow<Date>","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Timers cannot fail"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"App foreground\/background state"}]}],[{"type":"paragraph","inlineContent":[{"code":"Flow<ScenePhase>","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Notification-based, always succeeds"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Network search request"}]}],[{"type":"paragraph","inlineContent":[{"code":"ThrowingFlow<[Product]>","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"HTTP can fail with "},{"code":"URLError","type":"codeVoice"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Database query"}]}],[{"type":"paragraph","inlineContent":[{"code":"ThrowingFlow<[Article]>","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"SQLite\/CoreData can throw"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"File read"}]}],[{"type":"paragraph","inlineContent":[{"code":"ThrowingFlow<Data>","type":"codeVoice"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"File I\/O can fail"}]}]],[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Authenticated session state"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Depends (see below)"}]}],[{"type":"paragraph","inlineContent":[{"type":"text","text":"Refresh can fail; base state cannot"}]}]]],"type":"table","header":"row"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When in doubt, keep the boundary as close to the actual failure site as possible. A "},{"code":"Flow<String>","type":"codeVoice"},{"type":"text","text":" user-input stream should stay "},{"code":"Flow<String>","type":"codeVoice"},{"type":"text","text":" through debouncing and deduplication. Only the network call that consumes the query becomes a "},{"code":"ThrowingFlow","type":"codeVoice"},{"type":"text","text":"."}]},{"anchor":"Flow-non-failing-streams","type":"heading","level":2,"text":"Flow: non-failing streams"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"code":"FlowCore\/Flow","type":"codeVoice"},{"type":"text","text":" for streams whose source cannot produce an error. The compiler enforces this: "},{"code":"Flow.collect","type":"codeVoice"},{"type":"text","text":" does not "},{"code":"throws","type":"codeVoice"},{"type":"text","text":", so you cannot accidentally "},{"code":"try","type":"codeVoice"},{"type":"text","text":" out of it."}]},{"code":["\/\/ User's search query. Typed text cannot fail.","let searchQuery: Flow<String> = MutableStateFlow(\"\").asFlow()","    .debounce(for: .milliseconds(300))","    .removeDuplicates()","    .filter { !$0.isEmpty }","","\/\/ Location updates. Sensor delivery cannot fail (permission errors","\/\/ are a separate concern, handled by the CLLocationManager delegate).","let locationUpdates: Flow<CLLocation> = Flow { collector in","    let delegate = LocationDelegate()","    locationManager.delegate = delegate","    locationManager.startUpdatingLocation()","    for await location in delegate.locations {","        await collector.emit(location)","    }","}","","\/\/ Form field state. Derived from already-loaded data.","let isFormValid: Flow<Bool> = username.combineLatest(password) { user, pass in","    !user.isEmpty && pass.count >= 8","}"],"syntax":"swift","type":"codeListing"},{"anchor":"ThrowingFlow-fallible-streams","type":"heading","level":2,"text":"ThrowingFlow: fallible streams"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"code":"FlowCore\/ThrowingFlow","type":"codeVoice"},{"type":"text","text":" when the source can throw. The collector’s "},{"code":"emit","type":"codeVoice"},{"type":"text","text":" is "},{"code":"throws","type":"codeVoice"},{"type":"text","text":", so error propagation is explicit throughout the chain."}]},{"code":["\/\/ Network search. Can fail with URLError, server errors, or decoding errors.","let searchResults: ThrowingFlow<[Product]> = ThrowingFlow { collector in","    let url = SearchEndpoint.url(for: query)","    let (data, response) = try await URLSession.shared.data(from: url)","    guard (response as? HTTPURLResponse)?.statusCode == 200 else {","        throw SearchError.serverError","    }","    let products = try JSONDecoder().decode([Product].self, from: data)","    try await collector.emit(products)","}","","\/\/ Database query. Can fail if the database is unavailable or migrating.","let articles: ThrowingFlow<[Article]> = ThrowingFlow { collector in","    let cached = try await articleDatabase.fetchAll()","    try await collector.emit(cached)","    let fresh = try await articleAPI.fetchLatest()","    try await articleDatabase.upsert(fresh)","    try await collector.emit(fresh)","}"],"syntax":"swift","type":"codeListing"},{"level":2,"anchor":"Converting-between-the-two","type":"heading","text":"Converting between the two"},{"anchor":"ThrowingFlow-%E2%86%92-Flow-catch-errors-at-the-boundary","type":"heading","level":3,"text":"ThrowingFlow → Flow: catch errors at the boundary"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"code":"catch","type":"codeVoice"},{"text":" to handle errors and return a non-failing ","type":"text"},{"code":"Flow","type":"codeVoice"},{"text":". This is the most common conversion and keeps error handling close to the failure site:","type":"text"}]},{"code":["\/\/ The search UI should show an error state, never crash.","\/\/ Convert ThrowingFlow<[Product]> → Flow<SearchState> at the ViewModel layer.","let state: Flow<SearchState> = searchResults","    .map { SearchState.loaded($0) }","    .catch { error, collector in","        \/\/ Emit a fallback state. The flow becomes non-throwing.","        await collector.emit(.error(\"Search unavailable. Check your connection.\"))","    }"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"A more sophisticated fallback emits cached data before the error state:"}],"type":"paragraph"},{"syntax":"swift","code":["let articlesState: Flow<ArticleListState> = articleAPI.fetchLatest()","    .map { ArticleListState.loaded($0) }","    .catch { _, collector in","        if let cached = try? await articleDatabase.fetchAll(), !cached.isEmpty {","            await collector.emit(.loaded(cached))","        } else {","            await collector.emit(.empty)","        }","    }"],"type":"codeListing"},{"anchor":"ThrowingFlow-%E2%86%92-Flow-let-errors-propagate-handle-at-collection-site","level":3,"type":"heading","text":"ThrowingFlow → Flow: let errors propagate, handle at collection site"},{"inlineContent":[{"type":"text","text":"If you want to handle errors at the collection call site rather than inline, collect the "},{"code":"ThrowingFlow","type":"codeVoice"},{"type":"text","text":" directly with "},{"code":"try","type":"codeVoice"},{"type":"text","text":":"}],"type":"paragraph"},{"code":["do {","    try await productRepository.search(query).collect { products in","        display(products)","    }","} catch {","    showError(error)","}"],"type":"codeListing","syntax":"swift"},{"anchor":"Flow-%E2%86%92-ThrowingFlow-add-potential-failure","level":3,"type":"heading","text":"Flow → ThrowingFlow: add potential failure"},{"inlineContent":[{"type":"text","text":"When a non-failing operation precedes a potentially-failing one, "},{"code":"flatMapLatest","type":"codeVoice"},{"type":"text","text":" naturally bridges them because the transform closure returns a "},{"code":"ThrowingFlow","type":"codeVoice"},{"type":"text","text":":"}],"type":"paragraph"},{"code":["\/\/ searchQuery is Flow<String>. Text field, cannot fail.","\/\/ productRepository.search returns ThrowingFlow<[Product]>. Network, can fail.","let results: ThrowingFlow<[Product]> = searchQuery","    .flatMapLatest { query -> ThrowingFlow<[Product]> in","        query.isEmpty ? .empty : productRepository.search(query)","    }"],"type":"codeListing","syntax":"swift"},{"inlineContent":[{"type":"text","text":"The "},{"code":"flatMapLatest","type":"codeVoice"},{"type":"text","text":" overload on "},{"type":"codeVoice","code":"Flow"},{"type":"text","text":" that returns a "},{"type":"codeVoice","code":"ThrowingFlow"},{"type":"text","text":" produces a "},{"type":"codeVoice","code":"ThrowingFlow<U>"},{"text":", and the type system tracks the boundary automatically.","type":"text"}],"type":"paragraph"},{"text":"Pair example: form validation and submission","level":2,"anchor":"Pair-example-form-validation-and-submission","type":"heading"},{"inlineContent":[{"type":"text","text":"This illustrates the full lifecycle: non-failing form state, converting to throwing at the submission boundary, and recovering back to non-failing for the UI:"}],"type":"paragraph"},{"code":["\/\/ Form fields. Cannot fail, stay as Flow<String>.","let username: Flow<String> = usernameField.asFlow()","let password: Flow<String> = passwordField.asFlow()","","\/\/ Validation state. Derived, cannot fail.","let isValid: Flow<Bool> = username.combineLatest(password) { u, p in","    u.count >= 3 && p.count >= 8","}","","\/\/ On submit: crossing into ThrowingFlow at the network boundary.","func submit(username: String, password: String) -> ThrowingFlow<AuthSession> {","    ThrowingFlow { collector in","        let session = try await authService.login(username: username, password: password)","        try await collector.emit(session)","    }","}","","\/\/ ViewModel wires it all together, recovering to non-failing for the UI.","let authState: any StateFlow<AuthState> = submitTap","    .flatMapLatest { _ -> ThrowingFlow<AuthState> in","        submit(username: currentUsername, password: currentPassword)","            .map { AuthState.signedIn($0) }","    }","    .catch { _, collector in","        await collector.emit(.error(\"Login failed. Check your credentials.\"))","    }","    .asStateFlow(initialValue: .signedOut)"],"type":"codeListing","syntax":"swift"},{"text":"Related concepts","anchor":"Related-concepts","type":"heading","level":2},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/Flow\/documentation\/Flow\/HotVsColdStreams","isActive":true},{"type":"text","text":": when to convert a "},{"code":"Flow","type":"codeVoice"},{"type":"text","text":" to a hot "},{"code":"StateFlow","type":"codeVoice"},{"type":"text","text":" or "},{"code":"SharedFlow","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/Flow\/documentation\/Flow\/CancellationSemantics","type":"reference","isActive":true},{"text":": how cancellation propagates through both stream types","type":"text"}]}]}]}],"kind":"content"}],"variants":[{"paths":["\/documentation\/flow\/flowvsthrowingflow"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"A decision guide for choosing between "},{"code":"FlowCore\/Flow","type":"codeVoice"},{"type":"text","text":" and "},{"code":"FlowCore\/ThrowingFlow","type":"codeVoice"},{"type":"text","text":", and how to convert between them when your pipeline crosses the boundary."}],"sections":[],"kind":"article","identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Flow\/documentation\/Flow\/FlowVsThrowingFlow"},"references":{"doc://Flow/documentation/Flow":{"type":"topic","title":"Flow","kind":"symbol","abstract":[{"type":"text","text":"Kotlin Flow semantics in Swift, built on Swift 6.3 strict concurrency."}],"role":"collection","identifier":"doc:\/\/Flow\/documentation\/Flow","url":"\/documentation\/flow"},"doc://Flow/documentation/Flow/LifecycleAwareCollection":{"title":"Lifecycle-Aware Collection","kind":"article","identifier":"doc:\/\/Flow\/documentation\/Flow\/LifecycleAwareCollection","type":"topic","url":"\/documentation\/flow\/lifecycleawarecollection","role":"article","abstract":[{"type":"text","text":"Bind flow lifetimes to UI objects so collection starts when a view appears and stops automatically when it disappears."}]},"doc://Flow/documentation/Flow/HotVsColdStreams":{"title":"Hot vs Cold Streams","role":"article","abstract":[{"type":"text","text":"Cold streams run once per collector. Hot streams share a single execution across all collectors. Choosing the right kind prevents duplicate network requests, dropped events, and stale state."}],"kind":"article","type":"topic","url":"\/documentation\/flow\/hotvscoldstreams","identifier":"doc:\/\/Flow\/documentation\/Flow\/HotVsColdStreams"},"doc://Flow/documentation/Flow/CancellationSemantics":{"type":"topic","title":"Cancellation Semantics","kind":"article","abstract":[{"type":"text","text":"How cancellation flows from "},{"code":"FlowCore\/FlowScope","type":"codeVoice"},{"type":"text","text":" through Swift Tasks into flow bodies, and what goes wrong when you bypass the chain."}],"role":"article","identifier":"doc:\/\/Flow\/documentation\/Flow\/CancellationSemantics","url":"\/documentation\/flow\/cancellationsemantics"}}}