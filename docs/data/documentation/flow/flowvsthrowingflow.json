{"hierarchy":{"paths":[["doc:\/\/Flow\/documentation\/Flow"]]},"metadata":{"modules":[{"name":"Flow"}],"roleHeading":"Article","title":"Flow vs ThrowingFlow","role":"article"},"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/flow\/flowvsthrowingflow"]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Flow\/documentation\/Flow\/FlowVsThrowingFlow"},"sections":[],"seeAlsoSections":[{"anchor":"Getting-Started","title":"Getting Started","generated":true,"identifiers":["doc:\/\/Flow\/documentation\/Flow\/HotVsColdStreams","doc:\/\/Flow\/documentation\/Flow\/LifecycleAwareCollection"]}],"primaryContentSections":[{"content":[{"type":"heading","text":"Overview","anchor":"Overview","level":2},{"inlineContent":[{"type":"text","text":"FlowKit uses two distinct stream types rather than a single "},{"type":"codeVoice","code":"Result"},{"type":"text","text":"-emitting type. The distinction is load-bearing: the Swift compiler enforces it at call sites, operators are defined separately on each, and conversion between them is always explicit. This catches a whole class of bugs, such as silent error swallowing and incorrect error propagation, at compile time rather than runtime."}],"type":"paragraph"},{"anchor":"The-decision-rule","text":"The decision rule","level":2,"type":"heading"},{"inlineContent":[{"text":"Ask one question: ","type":"text"},{"type":"strong","inlineContent":[{"text":"can this source ever fail with an error?","type":"text"}]}],"type":"paragraph"},{"header":"row","rows":[[[{"type":"paragraph","inlineContent":[{"type":"text","text":"Source"}]}],[{"inlineContent":[{"text":"Type","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Reason"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Keyboard input from a "},{"type":"codeVoice","code":"UITextField"}],"type":"paragraph"}],[{"inlineContent":[{"code":"Flow<String>","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Text field observation cannot throw"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"GPS coordinates from ","type":"text"},{"code":"CLLocationManager","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"code":"Flow<CLLocation>","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Sensor callbacks are non-throwing","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Timer ticks","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"Flow<Date>"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Timers cannot fail"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"App foreground\/background state"}],"type":"paragraph"}],[{"inlineContent":[{"code":"Flow<ScenePhase>","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Notification-based, always succeeds","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Network search request"}],"type":"paragraph"}],[{"inlineContent":[{"code":"ThrowingFlow<[Product]>","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"HTTP can fail with ","type":"text"},{"type":"codeVoice","code":"URLError"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Database query","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"ThrowingFlow<[Article]>"}],"type":"paragraph"}],[{"inlineContent":[{"text":"SQLite\/CoreData can throw","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"File read","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"ThrowingFlow<Data>"}],"type":"paragraph"}],[{"inlineContent":[{"text":"File I\/O can fail","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Authenticated session state","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Depends (see below)","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Refresh can fail; base state cannot"}],"type":"paragraph"}]]],"type":"table"},{"inlineContent":[{"text":"When in doubt, keep the boundary as close to the actual failure site as possible. A ","type":"text"},{"code":"Flow<String>","type":"codeVoice"},{"text":" user-input stream should stay ","type":"text"},{"code":"Flow<String>","type":"codeVoice"},{"text":" through debouncing and deduplication. Only the network call that consumes the query becomes a ","type":"text"},{"code":"ThrowingFlow","type":"codeVoice"},{"text":".","type":"text"}],"type":"paragraph"},{"text":"Flow: non-failing streams","level":2,"type":"heading","anchor":"Flow-non-failing-streams"},{"inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":"FlowCore\/Flow"},{"type":"text","text":" for streams whose source cannot produce an error. The compiler enforces this: "},{"type":"codeVoice","code":"Flow.collect"},{"type":"text","text":" does not "},{"type":"codeVoice","code":"throws"},{"type":"text","text":", so you cannot accidentally "},{"type":"codeVoice","code":"try"},{"type":"text","text":" out of it."}],"type":"paragraph"},{"code":["\/\/ User's search query. Typed text cannot fail.","let searchQuery: Flow<String> = MutableStateFlow(\"\").asFlow()","    .debounce(for: .milliseconds(300))","    .removeDuplicates()","    .filter { !$0.isEmpty }","","\/\/ Location updates. Sensor delivery cannot fail (permission errors","\/\/ are a separate concern, handled by the CLLocationManager delegate).","let locationUpdates: Flow<CLLocation> = Flow { collector in","    let delegate = LocationDelegate()","    locationManager.delegate = delegate","    locationManager.startUpdatingLocation()","    for await location in delegate.locations {","        await collector.emit(location)","    }","}","","\/\/ Form field state. Derived from already-loaded data.","let isFormValid: Flow<Bool> = username.combineLatest(password) { user, pass in","    !user.isEmpty && pass.count >= 8","}"],"syntax":"swift","type":"codeListing"},{"anchor":"ThrowingFlow-fallible-streams","type":"heading","level":2,"text":"ThrowingFlow: fallible streams"},{"inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":"FlowCore\/ThrowingFlow"},{"type":"text","text":" when the source can throw. The collector’s "},{"type":"codeVoice","code":"emit"},{"type":"text","text":" is "},{"type":"codeVoice","code":"throws"},{"type":"text","text":", so error propagation is explicit throughout the chain."}],"type":"paragraph"},{"type":"codeListing","code":["\/\/ Network search. Can fail with URLError, server errors, or decoding errors.","let searchResults: ThrowingFlow<[Product]> = ThrowingFlow { collector in","    let url = SearchEndpoint.url(for: query)","    let (data, response) = try await URLSession.shared.data(from: url)","    guard (response as? HTTPURLResponse)?.statusCode == 200 else {","        throw SearchError.serverError","    }","    let products = try JSONDecoder().decode([Product].self, from: data)","    try await collector.emit(products)","}","","\/\/ Database query. Can fail if the database is unavailable or migrating.","let articles: ThrowingFlow<[Article]> = ThrowingFlow { collector in","    let cached = try await articleDatabase.fetchAll()","    try await collector.emit(cached)","    let fresh = try await articleAPI.fetchLatest()","    try await articleDatabase.upsert(fresh)","    try await collector.emit(fresh)","}"],"syntax":"swift"},{"anchor":"Converting-between-the-two","type":"heading","level":2,"text":"Converting between the two"},{"anchor":"ThrowingFlow-%E2%86%92-Flow-catch-errors-at-the-boundary","type":"heading","level":3,"text":"ThrowingFlow → Flow: catch errors at the boundary"},{"inlineContent":[{"type":"text","text":"Use "},{"code":"catch","type":"codeVoice"},{"type":"text","text":" to handle errors and return a non-failing "},{"code":"Flow","type":"codeVoice"},{"type":"text","text":". This is the most common conversion and keeps error handling close to the failure site:"}],"type":"paragraph"},{"type":"codeListing","code":["\/\/ The search UI should show an error state, never crash.","\/\/ Convert ThrowingFlow<[Product]> → Flow<SearchState> at the ViewModel layer.","let state: Flow<SearchState> = searchResults","    .map { SearchState.loaded($0) }","    .catch { error, collector in","        \/\/ Emit a fallback state. The flow becomes non-throwing.","        await collector.emit(.error(\"Search unavailable. Check your connection.\"))","    }"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"A more sophisticated fallback emits cached data before the error state:"}],"type":"paragraph"},{"type":"codeListing","code":["let articlesState: Flow<ArticleListState> = articleAPI.fetchLatest()","    .map { ArticleListState.loaded($0) }","    .catch { _, collector in","        if let cached = try? await articleDatabase.fetchAll(), !cached.isEmpty {","            await collector.emit(.loaded(cached))","        } else {","            await collector.emit(.empty)","        }","    }"],"syntax":"swift"},{"anchor":"ThrowingFlow-%E2%86%92-Flow-let-errors-propagate-handle-at-collection-site","type":"heading","level":3,"text":"ThrowingFlow → Flow: let errors propagate, handle at collection site"},{"inlineContent":[{"text":"If you want to handle errors at the collection call site rather than inline, collect the ","type":"text"},{"code":"ThrowingFlow","type":"codeVoice"},{"text":" directly with ","type":"text"},{"code":"try","type":"codeVoice"},{"text":":","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["do {","    try await productRepository.search(query).collect { products in","        display(products)","    }","} catch {","    showError(error)","}"],"syntax":"swift"},{"anchor":"Flow-%E2%86%92-ThrowingFlow-add-potential-failure","type":"heading","level":3,"text":"Flow → ThrowingFlow: add potential failure"},{"inlineContent":[{"text":"When a non-failing operation precedes a potentially-failing one, ","type":"text"},{"type":"codeVoice","code":"flatMapLatest"},{"text":" naturally bridges them because the transform closure returns a ","type":"text"},{"type":"codeVoice","code":"ThrowingFlow"},{"text":":","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["\/\/ searchQuery is Flow<String>. Text field, cannot fail.","\/\/ productRepository.search returns ThrowingFlow<[Product]>. Network, can fail.","let results: ThrowingFlow<[Product]> = searchQuery","    .flatMapLatest { query -> ThrowingFlow<[Product]> in","        query.isEmpty ? .empty : productRepository.search(query)","    }"],"syntax":"swift"},{"inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"flatMapLatest"},{"type":"text","text":" overload on "},{"type":"codeVoice","code":"Flow"},{"type":"text","text":" that returns a "},{"type":"codeVoice","code":"ThrowingFlow"},{"type":"text","text":" produces a "},{"type":"codeVoice","code":"ThrowingFlow<U>"},{"type":"text","text":", and the type system tracks the boundary automatically."}],"type":"paragraph"},{"anchor":"Pair-example-form-validation-and-submission","type":"heading","level":2,"text":"Pair example: form validation and submission"},{"inlineContent":[{"text":"This illustrates the full lifecycle: non-failing form state, converting to throwing at the submission boundary, and recovering back to non-failing for the UI:","type":"text"}],"type":"paragraph"},{"type":"codeListing","code":["\/\/ Form fields. Cannot fail, stay as Flow<String>.","let username: Flow<String> = usernameField.asFlow()","let password: Flow<String> = passwordField.asFlow()","","\/\/ Validation state. Derived, cannot fail.","let isValid: Flow<Bool> = username.combineLatest(password) { u, p in","    u.count >= 3 && p.count >= 8","}","","\/\/ On submit: crossing into ThrowingFlow at the network boundary.","func submit(username: String, password: String) -> ThrowingFlow<AuthSession> {","    ThrowingFlow { collector in","        let session = try await authService.login(username: username, password: password)","        try await collector.emit(session)","    }","}","","\/\/ ViewModel wires it all together, recovering to non-failing for the UI.","let authState: any StateFlow<AuthState> = submitTap","    .flatMapLatest { _ -> ThrowingFlow<AuthState> in","        submit(username: currentUsername, password: currentPassword)","            .map { AuthState.signedIn($0) }","    }","    .catch { _, collector in","        await collector.emit(.error(\"Login failed. Check your credentials.\"))","    }","    .asStateFlow(initialValue: .signedOut)"],"syntax":"swift"},{"anchor":"Related-concepts","type":"heading","level":2,"text":"Related concepts"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/Flow\/documentation\/Flow\/HotVsColdStreams"},{"text":": when to convert a ","type":"text"},{"code":"Flow","type":"codeVoice"},{"text":" to a hot ","type":"text"},{"code":"StateFlow","type":"codeVoice"},{"text":" or ","type":"text"},{"code":"SharedFlow","type":"codeVoice"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/Flow\/documentation\/Flow\/CancellationSemantics","isActive":true},{"type":"text","text":": how cancellation propagates through both stream types"}]}]}]}],"kind":"content"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"kind":"article","abstract":[{"type":"text","text":"A decision guide for choosing between "},{"code":"FlowCore\/Flow","type":"codeVoice"},{"type":"text","text":" and "},{"code":"FlowCore\/ThrowingFlow","type":"codeVoice"},{"type":"text","text":", and how to convert between them when your pipeline crosses the boundary."}],"references":{"doc://Flow/documentation/Flow/CancellationSemantics":{"title":"Cancellation Semantics","identifier":"doc:\/\/Flow\/documentation\/Flow\/CancellationSemantics","kind":"article","type":"topic","url":"\/documentation\/flow\/cancellationsemantics","role":"article","abstract":[{"type":"text","text":"How cancellation flows from "},{"code":"FlowCore\/FlowScope","type":"codeVoice"},{"type":"text","text":" through Swift Tasks into flow bodies, and what goes wrong when you bypass the chain."}]},"doc://Flow/documentation/Flow":{"kind":"symbol","identifier":"doc:\/\/Flow\/documentation\/Flow","title":"Flow","role":"collection","abstract":[{"type":"text","text":"Kotlin Flow semantics in Swift, built on Swift 6.3 strict concurrency."}],"type":"topic","url":"\/documentation\/flow"},"doc://Flow/documentation/Flow/LifecycleAwareCollection":{"kind":"article","type":"topic","title":"Lifecycle-Aware Collection","role":"article","url":"\/documentation\/flow\/lifecycleawarecollection","identifier":"doc:\/\/Flow\/documentation\/Flow\/LifecycleAwareCollection","abstract":[{"type":"text","text":"Bind flow lifetimes to UI objects so collection starts when a view appears and stops automatically when it disappears."}]},"doc://Flow/documentation/Flow/HotVsColdStreams":{"kind":"article","type":"topic","title":"Hot vs Cold Streams","role":"article","url":"\/documentation\/flow\/hotvscoldstreams","identifier":"doc:\/\/Flow\/documentation\/Flow\/HotVsColdStreams","abstract":[{"type":"text","text":"Cold streams run once per collector. Hot streams share a single execution across all collectors. Choosing the right kind prevents duplicate network requests, dropped events, and stale state."}]}}}