{"abstract":[{"type":"text","text":"A decision guide for choosing between "},{"type":"codeVoice","code":"FlowCore\/Flow"},{"type":"text","text":" and "},{"type":"codeVoice","code":"FlowCore\/ThrowingFlow"},{"type":"text","text":", and how to convert between them when your pipeline crosses the boundary."}],"metadata":{"roleHeading":"Article","role":"article","modules":[{"name":"Flow"}],"title":"Flow vs ThrowingFlow"},"hierarchy":{"paths":[["doc:\/\/Flow\/documentation\/Flow"]]},"kind":"article","schemaVersion":{"minor":3,"major":0,"patch":0},"seeAlsoSections":[{"anchor":"Getting-Started","title":"Getting Started","generated":true,"identifiers":["doc:\/\/Flow\/documentation\/Flow\/HotVsColdStreams","doc:\/\/Flow\/documentation\/Flow\/LifecycleAwareCollection"]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/flow\/flowvsthrowingflow"]}],"sections":[],"primaryContentSections":[{"content":[{"level":2,"anchor":"Overview","text":"Overview","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"FlowKit uses two distinct stream types rather than a single "},{"code":"Result","type":"codeVoice"},{"type":"text","text":"-emitting type. The distinction is load-bearing: the Swift compiler enforces it at call sites, operators are defined separately on each, and conversion between them is always explicit. This catches a whole class of bugs, such as silent error swallowing and incorrect error propagation, at compile time rather than runtime."}]},{"level":2,"anchor":"The-decision-rule","text":"The decision rule","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Ask one question: ","type":"text"},{"inlineContent":[{"type":"text","text":"can this source ever fail with an error?"}],"type":"strong"}]},{"rows":[[[{"inlineContent":[{"text":"Source","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Type"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Reason"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Keyboard input from a ","type":"text"},{"code":"UITextField","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"Flow<String>"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Text field observation cannot throw"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"GPS coordinates from ","type":"text"},{"code":"CLLocationManager","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"Flow<CLLocation>"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Sensor callbacks are non-throwing"}],"type":"paragraph"}]],[[{"inlineContent":[{"type":"text","text":"Timer ticks"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"Flow<Date>"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Timers cannot fail","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"App foreground\/background state","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"Flow<ScenePhase>"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Notification-based, always succeeds"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Network search request","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"ThrowingFlow<[Product]>"}],"type":"paragraph"}],[{"inlineContent":[{"text":"HTTP can fail with ","type":"text"},{"code":"URLError","type":"codeVoice"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Database query","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"code":"ThrowingFlow<[Article]>","type":"codeVoice"}],"type":"paragraph"}],[{"inlineContent":[{"text":"SQLite\/CoreData can throw","type":"text"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"File read","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"codeVoice","code":"ThrowingFlow<Data>"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"File I\/O can fail"}],"type":"paragraph"}]],[[{"inlineContent":[{"text":"Authenticated session state","type":"text"}],"type":"paragraph"}],[{"inlineContent":[{"type":"text","text":"Depends (see below)"}],"type":"paragraph"}],[{"inlineContent":[{"text":"Refresh can fail; base state cannot","type":"text"}],"type":"paragraph"}]]],"header":"row","type":"table"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When in doubt, keep the boundary as close to the actual failure site as possible. A "},{"type":"codeVoice","code":"Flow<String>"},{"type":"text","text":" user-input stream should stay "},{"type":"codeVoice","code":"Flow<String>"},{"type":"text","text":" through debouncing and deduplication. Only the network call that consumes the query becomes a "},{"type":"codeVoice","code":"ThrowingFlow"},{"type":"text","text":"."}]},{"level":2,"anchor":"Flow-non-failing-streams","text":"Flow: non-failing streams","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Use "},{"type":"codeVoice","code":"FlowCore\/Flow"},{"type":"text","text":" for streams whose source cannot produce an error. The compiler enforces this: "},{"type":"codeVoice","code":"Flow.collect"},{"type":"text","text":" does not "},{"type":"codeVoice","code":"throws"},{"type":"text","text":", so you cannot accidentally "},{"type":"codeVoice","code":"try"},{"type":"text","text":" out of it."}]},{"syntax":"swift","type":"codeListing","code":["\/\/ User's search query. Typed text cannot fail.","let searchQuery: Flow<String> = MutableStateFlow(\"\").asFlow()","    .debounce(for: .milliseconds(300))","    .removeDuplicates()","    .filter { !$0.isEmpty }","","\/\/ Location updates. Sensor delivery cannot fail (permission errors","\/\/ are a separate concern, handled by the CLLocationManager delegate).","let locationUpdates: Flow<CLLocation> = Flow { collector in","    let delegate = LocationDelegate()","    locationManager.delegate = delegate","    locationManager.startUpdatingLocation()","    for await location in delegate.locations {","        await collector.emit(location)","    }","}","","\/\/ Form field state. Derived from already-loaded data.","let isFormValid: Flow<Bool> = username.combineLatest(password) { user, pass in","    !user.isEmpty && pass.count >= 8","}"]},{"level":2,"anchor":"ThrowingFlow-fallible-streams","text":"ThrowingFlow: fallible streams","type":"heading"},{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"code":"FlowCore\/ThrowingFlow","type":"codeVoice"},{"text":" when the source can throw. The collector’s ","type":"text"},{"code":"emit","type":"codeVoice"},{"text":" is ","type":"text"},{"code":"throws","type":"codeVoice"},{"text":", so error propagation is explicit throughout the chain.","type":"text"}]},{"code":["\/\/ Network search. Can fail with URLError, server errors, or decoding errors.","let searchResults: ThrowingFlow<[Product]> = ThrowingFlow { collector in","    let url = SearchEndpoint.url(for: query)","    let (data, response) = try await URLSession.shared.data(from: url)","    guard (response as? HTTPURLResponse)?.statusCode == 200 else {","        throw SearchError.serverError","    }","    let products = try JSONDecoder().decode([Product].self, from: data)","    try await collector.emit(products)","}","","\/\/ Database query. Can fail if the database is unavailable or migrating.","let articles: ThrowingFlow<[Article]> = ThrowingFlow { collector in","    let cached = try await articleDatabase.fetchAll()","    try await collector.emit(cached)","    let fresh = try await articleAPI.fetchLatest()","    try await articleDatabase.upsert(fresh)","    try await collector.emit(fresh)","}"],"type":"codeListing","syntax":"swift"},{"text":"Converting between the two","type":"heading","level":2,"anchor":"Converting-between-the-two"},{"text":"ThrowingFlow → Flow: catch errors at the boundary","type":"heading","level":3,"anchor":"ThrowingFlow-%E2%86%92-Flow-catch-errors-at-the-boundary"},{"type":"paragraph","inlineContent":[{"text":"Use ","type":"text"},{"code":"catch","type":"codeVoice"},{"text":" to handle errors and return a non-failing ","type":"text"},{"code":"Flow","type":"codeVoice"},{"text":". This is the most common conversion and keeps error handling close to the failure site:","type":"text"}]},{"code":["\/\/ The search UI should show an error state, never crash.","\/\/ Convert ThrowingFlow<[Product]> → Flow<SearchState> at the ViewModel layer.","let state: Flow<SearchState> = searchResults","    .map { SearchState.loaded($0) }","    .catch { error, collector in","        \/\/ Emit a fallback state. The flow becomes non-throwing.","        await collector.emit(.error(\"Search unavailable. Check your connection.\"))","    }"],"type":"codeListing","syntax":"swift"},{"type":"paragraph","inlineContent":[{"text":"A more sophisticated fallback emits cached data before the error state:","type":"text"}]},{"code":["let articlesState: Flow<ArticleListState> = articleAPI.fetchLatest()","    .map { ArticleListState.loaded($0) }","    .catch { _, collector in","        if let cached = try? await articleDatabase.fetchAll(), !cached.isEmpty {","            await collector.emit(.loaded(cached))","        } else {","            await collector.emit(.empty)","        }","    }"],"type":"codeListing","syntax":"swift"},{"text":"ThrowingFlow → Flow: let errors propagate, handle at collection site","type":"heading","level":3,"anchor":"ThrowingFlow-%E2%86%92-Flow-let-errors-propagate-handle-at-collection-site"},{"type":"paragraph","inlineContent":[{"type":"text","text":"If you want to handle errors at the collection call site rather than inline, collect the "},{"type":"codeVoice","code":"ThrowingFlow"},{"type":"text","text":" directly with "},{"type":"codeVoice","code":"try"},{"type":"text","text":":"}]},{"code":["do {","    try await productRepository.search(query).collect { products in","        display(products)","    }","} catch {","    showError(error)","}"],"type":"codeListing","syntax":"swift"},{"level":3,"text":"Flow → ThrowingFlow: add potential failure","anchor":"Flow-%E2%86%92-ThrowingFlow-add-potential-failure","type":"heading"},{"inlineContent":[{"type":"text","text":"When a non-failing operation precedes a potentially-failing one, "},{"type":"codeVoice","code":"flatMapLatest"},{"type":"text","text":" naturally bridges them because the transform closure returns a "},{"type":"codeVoice","code":"ThrowingFlow"},{"type":"text","text":":"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ searchQuery is Flow<String>. Text field, cannot fail.","\/\/ productRepository.search returns ThrowingFlow<[Product]>. Network, can fail.","let results: ThrowingFlow<[Product]> = searchQuery","    .flatMapLatest { query -> ThrowingFlow<[Product]> in","        query.isEmpty ? .empty : productRepository.search(query)","    }"],"type":"codeListing"},{"inlineContent":[{"type":"text","text":"The "},{"code":"flatMapLatest","type":"codeVoice"},{"type":"text","text":" overload on "},{"code":"Flow","type":"codeVoice"},{"type":"text","text":" that returns a "},{"code":"ThrowingFlow","type":"codeVoice"},{"type":"text","text":" produces a "},{"code":"ThrowingFlow<U>","type":"codeVoice"},{"type":"text","text":", and the type system tracks the boundary automatically."}],"type":"paragraph"},{"level":2,"text":"Pair example: form validation and submission","anchor":"Pair-example-form-validation-and-submission","type":"heading"},{"inlineContent":[{"type":"text","text":"This illustrates the full lifecycle: non-failing form state, converting to throwing at the submission boundary, and recovering back to non-failing for the UI:"}],"type":"paragraph"},{"syntax":"swift","code":["\/\/ Form fields. Cannot fail, stay as Flow<String>.","let username: Flow<String> = usernameField.asFlow()","let password: Flow<String> = passwordField.asFlow()","","\/\/ Validation state. Derived, cannot fail.","let isValid: Flow<Bool> = username.combineLatest(password) { u, p in","    u.count >= 3 && p.count >= 8","}","","\/\/ On submit: crossing into ThrowingFlow at the network boundary.","func submit(username: String, password: String) -> ThrowingFlow<AuthSession> {","    ThrowingFlow { collector in","        let session = try await authService.login(username: username, password: password)","        try await collector.emit(session)","    }","}","","\/\/ ViewModel wires it all together, recovering to non-failing for the UI.","let authState: any StateFlow<AuthState> = submitTap","    .flatMapLatest { _ -> ThrowingFlow<AuthState> in","        submit(username: currentUsername, password: currentPassword)","            .map { AuthState.signedIn($0) }","    }","    .catch { _, collector in","        await collector.emit(.error(\"Login failed. Check your credentials.\"))","    }","    .asStateFlow(initialValue: .signedOut)"],"type":"codeListing"},{"level":2,"text":"Related concepts","anchor":"Related-concepts","type":"heading"},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/Flow\/documentation\/Flow\/HotVsColdStreams","type":"reference","isActive":true},{"text":": when to convert a ","type":"text"},{"type":"codeVoice","code":"Flow"},{"text":" to a hot ","type":"text"},{"type":"codeVoice","code":"StateFlow"},{"text":" or ","type":"text"},{"type":"codeVoice","code":"SharedFlow"}]}]},{"content":[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/Flow\/documentation\/Flow\/CancellationSemantics"},{"text":": how cancellation propagates through both stream types","type":"text"}],"type":"paragraph"}]}],"type":"unorderedList"}],"kind":"content"}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Flow\/documentation\/Flow\/FlowVsThrowingFlow"},"references":{"doc://Flow/documentation/Flow/LifecycleAwareCollection":{"url":"\/documentation\/flow\/lifecycleawarecollection","kind":"article","type":"topic","abstract":[{"type":"text","text":"Bind flow lifetimes to UI objects so collection starts when a view appears and stops automatically when it disappears."}],"role":"article","identifier":"doc:\/\/Flow\/documentation\/Flow\/LifecycleAwareCollection","title":"Lifecycle-Aware Collection"},"doc://Flow/documentation/Flow/CancellationSemantics":{"url":"\/documentation\/flow\/cancellationsemantics","abstract":[{"text":"How cancellation flows from ","type":"text"},{"code":"FlowCore\/FlowScope","type":"codeVoice"},{"text":" through Swift Tasks into flow bodies, and what goes wrong when you bypass the chain.","type":"text"}],"type":"topic","identifier":"doc:\/\/Flow\/documentation\/Flow\/CancellationSemantics","role":"article","kind":"article","title":"Cancellation Semantics"},"doc://Flow/documentation/Flow":{"kind":"symbol","type":"topic","url":"\/documentation\/flow","abstract":[{"text":"Kotlin Flow semantics in Swift, built on Swift 6.3 strict concurrency.","type":"text"}],"identifier":"doc:\/\/Flow\/documentation\/Flow","role":"collection","title":"Flow"},"doc://Flow/documentation/Flow/HotVsColdStreams":{"title":"Hot vs Cold Streams","role":"article","url":"\/documentation\/flow\/hotvscoldstreams","abstract":[{"type":"text","text":"Cold streams run once per collector. Hot streams share a single execution across all collectors. Choosing the right kind prevents duplicate network requests, dropped events, and stale state."}],"identifier":"doc:\/\/Flow\/documentation\/Flow\/HotVsColdStreams","type":"topic","kind":"article"}}}