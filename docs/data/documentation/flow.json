{"topicSections":[{"anchor":"Getting-Started","title":"Getting Started","identifiers":["doc:\/\/Flow\/documentation\/Flow\/HotVsColdStreams","doc:\/\/Flow\/documentation\/Flow\/FlowVsThrowingFlow","doc:\/\/Flow\/documentation\/Flow\/LifecycleAwareCollection"]},{"title":"Core Concepts","anchor":"Core-Concepts","identifiers":["doc:\/\/Flow\/documentation\/Flow\/CancellationSemantics","doc:\/\/Flow\/documentation\/Flow\/KotlinFlowMigration"]}],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","anchor":"Overview","level":2,"text":"Overview"},{"type":"paragraph","inlineContent":[{"text":"FlowKit brings the Kotlin Flow mental model to Swift: cold asynchronous streams (","type":"text"},{"type":"codeVoice","code":"FlowCore\/Flow"},{"text":", ","type":"text"},{"type":"codeVoice","code":"FlowCore\/ThrowingFlow"},{"text":"), hot multicast primitives (","type":"text"},{"type":"codeVoice","code":"FlowHotStreams\/StateFlow"},{"text":", ","type":"text"},{"type":"codeVoice","code":"FlowHotStreams\/SharedFlow"},{"text":"), a rich operator library, and built-in testing infrastructure with virtual time.","type":"text"}]},{"text":"End-to-end example","anchor":"End-to-end-example","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"A search feature with debouncing, cancellation of in-flight queries, error fallback, and SwiftUI binding:"}]},{"type":"codeListing","code":["import Flow","import FlowUI","","@Observable","@MainActor","final class SearchViewModel {","    private let repository: ProductRepository","    private let query = MutableStateFlow(\"\")","    let results: any StateFlow<SearchState>","","    init(repository: ProductRepository) {","        self.repository = repository","        self.results = query.asFlow()","            .debounce(for: .milliseconds(300))","            .removeDuplicates()","            .flatMapLatest { query -> ThrowingFlow<[Product]> in","                query.isEmpty ? .empty : repository.search(query)","            }","            .map { SearchState.loaded($0) }","            .catch { _, collector in","                await collector.emit(.error(\"Search failed\"))","            }","            .asStateFlow(initialValue: .idle, strategy: .whileSubscribed(stopTimeout: .seconds(5)))","    }","","    func update(query text: String) async {","        await query.send(text)","    }","}","","struct SearchView: View {","    @Bindable var viewModel: SearchViewModel","    @CollectedState(viewModel.results) var state: SearchState = .idle","    @State private var query = \"\"","","    var body: some View {","        VStack {","            TextField(\"Search\", text: $query)","                .onChange(of: query) { _, new in","                    Task { await viewModel.update(query: new) }","                }","            switch state {","            case .idle: ContentUnavailableView(\"Start typing\", systemImage: \"magnifyingglass\")","            case .loaded(let products): List(products) { ProductRow(product: $0) }","            case .error(let message): Text(message).foregroundStyle(.red)","            }","        }","    }","}"],"syntax":"swift"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Every piece, from cold "},{"type":"codeVoice","code":"FlowCore\/Flow"},{"type":"text","text":" composition, debouncing, and error handling to hot "},{"type":"codeVoice","code":"FlowHotStreams\/StateFlow"},{"type":"text","text":" sharing and SwiftUI binding, is 0.1.0-through-0.4.0 API."}]}]}],"sections":[],"variants":[{"paths":["\/documentation\/flow"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[[]]},"abstract":[{"text":"Kotlin Flow semantics in Swift, built on Swift 6.3 strict concurrency.","type":"text"}],"schemaVersion":{"patch":0,"major":0,"minor":3},"kind":"symbol","metadata":{"title":"Flow","symbolKind":"module","role":"collection","externalID":"Flow","roleHeading":"Framework","modules":[{"name":"Flow"}]},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Flow\/documentation\/Flow"},"references":{"doc://Flow/documentation/Flow":{"identifier":"doc:\/\/Flow\/documentation\/Flow","abstract":[{"type":"text","text":"Kotlin Flow semantics in Swift, built on Swift 6.3 strict concurrency."}],"role":"collection","kind":"symbol","url":"\/documentation\/flow","title":"Flow","type":"topic"},"doc://Flow/documentation/Flow/CancellationSemantics":{"identifier":"doc:\/\/Flow\/documentation\/Flow\/CancellationSemantics","kind":"article","url":"\/documentation\/flow\/cancellationsemantics","role":"article","title":"Cancellation Semantics","abstract":[{"type":"text","text":"How cancellation flows from "},{"code":"FlowCore\/FlowScope","type":"codeVoice"},{"type":"text","text":" through Swift Tasks into flow bodies, and what goes wrong when you bypass the chain."}],"type":"topic"},"doc://Flow/documentation/Flow/LifecycleAwareCollection":{"kind":"article","type":"topic","title":"Lifecycle-Aware Collection","role":"article","url":"\/documentation\/flow\/lifecycleawarecollection","identifier":"doc:\/\/Flow\/documentation\/Flow\/LifecycleAwareCollection","abstract":[{"type":"text","text":"Bind flow lifetimes to UI objects so collection starts when a view appears and stops automatically when it disappears."}]},"doc://Flow/documentation/Flow/HotVsColdStreams":{"kind":"article","type":"topic","title":"Hot vs Cold Streams","role":"article","url":"\/documentation\/flow\/hotvscoldstreams","identifier":"doc:\/\/Flow\/documentation\/Flow\/HotVsColdStreams","abstract":[{"type":"text","text":"Cold streams run once per collector. Hot streams share a single execution across all collectors. Choosing the right kind prevents duplicate network requests, dropped events, and stale state."}]},"doc://Flow/documentation/Flow/KotlinFlowMigration":{"role":"article","kind":"article","title":"Kotlin Flow to FlowKit Migration Guide","type":"topic","abstract":[{"type":"text","text":"A complete mapping from Kotlin Flow APIs to their FlowKit equivalents, with side-by-side code comparisons for the most common patterns."}],"url":"\/documentation\/flow\/kotlinflowmigration","identifier":"doc:\/\/Flow\/documentation\/Flow\/KotlinFlowMigration"},"doc://Flow/documentation/Flow/FlowVsThrowingFlow":{"url":"\/documentation\/flow\/flowvsthrowingflow","title":"Flow vs ThrowingFlow","abstract":[{"type":"text","text":"A decision guide for choosing between "},{"type":"codeVoice","code":"FlowCore\/Flow"},{"type":"text","text":" and "},{"type":"codeVoice","code":"FlowCore\/ThrowingFlow"},{"type":"text","text":", and how to convert between them when your pipeline crosses the boundary."}],"role":"article","kind":"article","identifier":"doc:\/\/Flow\/documentation\/Flow\/FlowVsThrowingFlow","type":"topic"}}}