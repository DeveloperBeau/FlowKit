binding:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["import Flow","import FlowUI","","@Observable","@MainActor","final class SearchViewModel {","    private let repository: ProductRepository","    private let query = MutableStateFlow(\"\")","    let results: any StateFlow<SearchState>","","    init(repository: ProductRepository) {","        self.repository = repository","        self.results = query.asFlow()","            .debounce(for: .milliseconds(300))","            .removeDuplicates()","            .flatMapLatest { query -> ThrowingFlow<[Product]> in","                query.isEmpty ? .empty : repository.search(query)","            }","            .map { SearchState.loaded($0) }","            .catch { _, collector in","                await collector.emit(.error(\"Search failed\"))","            }","            .asStateFlow(initialValue: .idle, strategy: .whileSubscribed(stopTimeout: .seconds(5)))","    }","","    func update(query text: String) async {","        await query.send(text)","    }","}","","struct SearchView: View {","    @Bindable var viewModel: SearchViewModel","    @CollectedState(viewModel.results) var state: SearchState = .idle","    @State private var query = \"\"","","    var body: some View {","        VStack {","            TextField(\"Search\", text: $query)","                .onChange(of: query) { _, new in","                    Task { await viewModel.update(query: new) }","                }","            switch state {","            case .idle: ContentUnavailableView(\"Start typing\", systemImage: \"magnifyingglass\")","            case .loaded(let products): List(products) { ProductRow(product: $0) }","            case .error(let message): Text(message).foregroundStyle(.red)","            }","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"text":"Every piece, from cold ","type":"text"},{"type":"codeVoice","code":"FlowCore\/Flow"},{"text":" composition, debouncing, and error handling to hot ","type":"text"},{"type":"codeVoice","code":"FlowHotStreams\/StateFlow"},{"text":" sharing and SwiftUI binding, is 0.1.0-through-0.4.0 API.","type":"text"}]}]}],"references":{"doc://Flow/documentation/Flow/LifecycleAwareCollection":{"url":"\/documentation\/flow\/lifecycleawarecollection","kind":"article","type":"topic","abstract":[{"type":"text","text":"Bind flow lifetimes to UI objects so collection starts when a view appears and stops automatically when it disappears."}],"role":"article","identifier":"doc:\/\/Flow\/documentation\/Flow\/LifecycleAwareCollection","title":"Lifecycle-Aware Collection"},"doc://Flow/documentation/Flow/CancellationSemantics":{"url":"\/documentation\/flow\/cancellationsemantics","abstract":[{"text":"How cancellation flows from ","type":"text"},{"code":"FlowCore\/FlowScope","type":"codeVoice"},{"text":" through Swift Tasks into flow bodies, and what goes wrong when you bypass the chain.","type":"text"}],"type":"topic","identifier":"doc:\/\/Flow\/documentation\/Flow\/CancellationSemantics","role":"article","kind":"article","title":"Cancellation Semantics"},"doc://Flow/documentation/Flow/KotlinFlowMigration":{"identifier":"doc:\/\/Flow\/documentation\/Flow\/KotlinFlowMigration","kind":"article","role":"article","title":"Kotlin Flow to FlowKit Migration Guide","url":"\/documentation\/flow\/kotlinflowmigration","abstract":[{"type":"text","text":"A complete mapping from Kotlin Flow APIs to their FlowKit equivalents, with side-by-side code comparisons for the most common patterns."}],"type":"topic"},"doc://Flow/documentation/Flow/HotVsColdStreams":{"title":"Hot vs Cold Streams","role":"article","url":"\/documentation\/flow\/hotvscoldstreams","abstract":[{"type":"text","text":"Cold streams run once per collector. Hot streams share a single execution across all collectors. Choosing the right kind prevents duplicate network requests, dropped events, and stale state."}],"identifier":"doc:\/\/Flow\/documentation\/Flow\/HotVsColdStreams","type":"topic","kind":"article"},"doc://Flow/tutorials/FlowKit":{"role":"overview","title":"Meet FlowKit","kind":"overview","url":"\/tutorials\/flowkit","abstract":[{"type":"text","text":"Learn FlowKit by building real features. These tutorials walk through"},{"type":"text","text":" "},{"type":"text","text":"the patterns that come up most often: search-as-you-type, shared state"},{"type":"text","text":" "},{"type":"text","text":"across screens, wrapping callback APIs, and writing deterministic tests."}],"type":"topic","identifier":"doc:\/\/Flow\/tutorials\/FlowKit"},"doc://Flow/documentation/Flow/FlowVsThrowingFlow":{"abstract":[{"text":"A decision guide for choosing between ","type":"text"},{"code":"FlowCore\/Flow","type":"codeVoice"},{"text":" and ","type":"text"},{"code":"FlowCore\/ThrowingFlow","type":"codeVoice"},{"text":", and how to convert between them when your pipeline crosses the boundary.","type":"text"}],"identifier":"doc:\/\/Flow\/documentation\/Flow\/FlowVsThrowingFlow","url":"\/documentation\/flow\/flowvsthrowingflow","title":"Flow vs ThrowingFlow","role":"article","type":"topic","kind":"article"},"doc://Flow/documentation/Flow":{"kind":"symbol","type":"topic","url":"\/documentation\/flow","abstract":[{"text":"Kotlin Flow semantics in Swift, built on Swift 6.3 strict concurrency.","type":"text"}],"identifier":"doc:\/\/Flow\/documentation\/Flow","role":"collection","title":"Flow"}}}