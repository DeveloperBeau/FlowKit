{"abstract":[{"type":"text","text":"Kotlin Flow semantics in Swift, built on Swift 6.3 strict concurrency."}],"hierarchy":{"paths":[[]]},"metadata":{"title":"Flow","modules":[{"name":"Flow"}],"externalID":"Flow","roleHeading":"Framework","symbolKind":"module","role":"collection"},"schemaVersion":{"major":0,"patch":0,"minor":3},"primaryContentSections":[{"kind":"content","content":[{"level":2,"type":"heading","anchor":"Overview","text":"Overview"},{"type":"paragraph","inlineContent":[{"type":"text","text":"FlowKit brings the Kotlin Flow mental model to Swift: cold asynchronous streams ("},{"type":"codeVoice","code":"FlowCore\/Flow"},{"type":"text","text":", "},{"type":"codeVoice","code":"FlowCore\/ThrowingFlow"},{"type":"text","text":"), hot multicast primitives ("},{"type":"codeVoice","code":"FlowHotStreams\/StateFlow"},{"type":"text","text":", "},{"type":"codeVoice","code":"FlowHotStreams\/SharedFlow"},{"type":"text","text":"), a rich operator library, and built-in testing infrastructure with virtual time."}]},{"level":2,"type":"heading","anchor":"End-to-end-example","text":"End-to-end example"},{"type":"paragraph","inlineContent":[{"type":"text","text":"A search feature with debouncing, cancellation of in-flight queries, error fallback, and SwiftUI binding:"}]},{"syntax":"swift","type":"codeListing","code":["import Flow","import FlowUI","","@Observable","@MainActor","final class SearchViewModel {","    private let repository: ProductRepository","    private let query = MutableStateFlow(\"\")","    let results: any StateFlow<SearchState>","","    init(repository: ProductRepository) {","        self.repository = repository","        self.results = query.asFlow()","            .debounce(for: .milliseconds(300))","            .removeDuplicates()","            .flatMapLatest { query -> ThrowingFlow<[Product]> in","                query.isEmpty ? .empty : repository.search(query)","            }","            .map { SearchState.loaded($0) }","            .catch { _, collector in","                await collector.emit(.error(\"Search failed\"))","            }","            .asStateFlow(initialValue: .idle, strategy: .whileSubscribed(stopTimeout: .seconds(5)))","    }","","    func update(query text: String) async {","        await query.send(text)","    }","}","","struct SearchView: View {","    @Bindable var viewModel: SearchViewModel","    @CollectedState(viewModel.results) var state: SearchState = .idle","    @State private var query = \"\"","","    var body: some View {","        VStack {","            TextField(\"Search\", text: $query)","                .onChange(of: query) { _, new in","                    Task { await viewModel.update(query: new) }","                }","            switch state {","            case .idle: ContentUnavailableView(\"Start typing\", systemImage: \"magnifyingglass\")","            case .loaded(let products): List(products) { ProductRow(product: $0) }","            case .error(let message): Text(message).foregroundStyle(.red)","            }","        }","    }","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Every piece, from cold "},{"type":"codeVoice","code":"FlowCore\/Flow"},{"type":"text","text":" composition, debouncing, and error handling to hot "},{"type":"codeVoice","code":"FlowHotStreams\/StateFlow"},{"type":"text","text":" sharing and SwiftUI binding, is 0.1.0-through-0.4.0 API."}]}]}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/Flow\/documentation\/Flow"},"kind":"symbol","topicSections":[{"identifiers":["doc:\/\/Flow\/documentation\/Flow\/HotVsColdStreams","doc:\/\/Flow\/documentation\/Flow\/FlowVsThrowingFlow","doc:\/\/Flow\/documentation\/Flow\/LifecycleAwareCollection"],"anchor":"Getting-Started","title":"Getting Started"},{"identifiers":["doc:\/\/Flow\/tutorials\/FlowKit"],"anchor":"Tutorials","title":"Tutorials"},{"identifiers":["doc:\/\/Flow\/documentation\/Flow\/CancellationSemantics","doc:\/\/Flow\/documentation\/Flow\/KotlinFlowMigration"],"anchor":"Core-Concepts","title":"Core Concepts"}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/flow"]}],"references":{"doc://Flow/documentation/Flow/FlowVsThrowingFlow":{"title":"Flow vs ThrowingFlow","kind":"article","type":"topic","identifier":"doc:\/\/Flow\/documentation\/Flow\/FlowVsThrowingFlow","url":"\/documentation\/flow\/flowvsthrowingflow","role":"article","abstract":[{"type":"text","text":"A decision guide for choosing between "},{"code":"FlowCore\/Flow","type":"codeVoice"},{"type":"text","text":" and "},{"code":"FlowCore\/ThrowingFlow","type":"codeVoice"},{"type":"text","text":", and how to convert between them when your pipeline crosses the boundary."}]},"doc://Flow/tutorials/FlowKit":{"type":"topic","title":"Meet FlowKit","kind":"overview","abstract":[{"text":"Learn FlowKit by building real features. These tutorials walk through","type":"text"},{"text":" ","type":"text"},{"text":"the patterns that come up most often: search-as-you-type, shared state","type":"text"},{"text":" ","type":"text"},{"text":"across screens, wrapping callback APIs, and writing deterministic tests.","type":"text"}],"role":"overview","identifier":"doc:\/\/Flow\/tutorials\/FlowKit","url":"\/tutorials\/flowkit"},"doc://Flow/documentation/Flow":{"type":"topic","title":"Flow","kind":"symbol","abstract":[{"type":"text","text":"Kotlin Flow semantics in Swift, built on Swift 6.3 strict concurrency."}],"role":"collection","identifier":"doc:\/\/Flow\/documentation\/Flow","url":"\/documentation\/flow"},"doc://Flow/documentation/Flow/CancellationSemantics":{"type":"topic","title":"Cancellation Semantics","kind":"article","abstract":[{"type":"text","text":"How cancellation flows from "},{"code":"FlowCore\/FlowScope","type":"codeVoice"},{"type":"text","text":" through Swift Tasks into flow bodies, and what goes wrong when you bypass the chain."}],"role":"article","identifier":"doc:\/\/Flow\/documentation\/Flow\/CancellationSemantics","url":"\/documentation\/flow\/cancellationsemantics"},"doc://Flow/documentation/Flow/HotVsColdStreams":{"title":"Hot vs Cold Streams","role":"article","abstract":[{"type":"text","text":"Cold streams run once per collector. Hot streams share a single execution across all collectors. Choosing the right kind prevents duplicate network requests, dropped events, and stale state."}],"kind":"article","type":"topic","url":"\/documentation\/flow\/hotvscoldstreams","identifier":"doc:\/\/Flow\/documentation\/Flow\/HotVsColdStreams"},"doc://Flow/documentation/Flow/KotlinFlowMigration":{"title":"Kotlin Flow to FlowKit Migration Guide","kind":"article","type":"topic","identifier":"doc:\/\/Flow\/documentation\/Flow\/KotlinFlowMigration","url":"\/documentation\/flow\/kotlinflowmigration","role":"article","abstract":[{"type":"text","text":"A complete mapping from Kotlin Flow APIs to their FlowKit equivalents, with side-by-side code comparisons for the most common patterns."}]},"doc://Flow/documentation/Flow/LifecycleAwareCollection":{"title":"Lifecycle-Aware Collection","kind":"article","identifier":"doc:\/\/Flow\/documentation\/Flow\/LifecycleAwareCollection","type":"topic","url":"\/documentation\/flow\/lifecycleawarecollection","role":"article","abstract":[{"type":"text","text":"Bind flow lifetimes to UI objects so collection starts when a view appears and stops automatically when it disappears."}]}}}