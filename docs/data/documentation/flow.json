{"schemaVersion":{"minor":3,"major":0,"patch":0},"hierarchy":{"paths":[[]]},"topicSections":[{"title":"Getting Started","identifiers":["doc:\/\/Flow\/documentation\/Flow\/HotVsColdStreams","doc:\/\/Flow\/documentation\/Flow\/FlowVsThrowingFlow","doc:\/\/Flow\/documentation\/Flow\/LifecycleAwareCollection"],"anchor":"Getting-Started"},{"title":"Core Concepts","identifiers":["doc:\/\/Flow\/documentation\/Flow\/CancellationSemantics","doc:\/\/Flow\/documentation\/Flow\/KotlinFlowMigration"],"anchor":"Core-Concepts"}],"identifier":{"url":"doc:\/\/Flow\/documentation\/Flow","interfaceLanguage":"swift"},"abstract":[{"text":"Kotlin Flow semantics in Swift, built on Swift 6.3 strict concurrency.","type":"text"}],"sections":[],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/flow"]}],"primaryContentSections":[{"kind":"content","content":[{"level":2,"text":"Overview","anchor":"Overview","type":"heading"},{"inlineContent":[{"type":"text","text":"FlowKit brings the Kotlin Flow mental model to Swift: cold asynchronous streams ("},{"type":"codeVoice","code":"FlowCore\/Flow"},{"type":"text","text":", "},{"type":"codeVoice","code":"FlowCore\/ThrowingFlow"},{"type":"text","text":"), hot multicast primitives ("},{"type":"codeVoice","code":"FlowHotStreams\/StateFlow"},{"type":"text","text":", "},{"type":"codeVoice","code":"FlowHotStreams\/SharedFlow"},{"type":"text","text":"), a rich operator library, and built-in testing infrastructure with virtual time."}],"type":"paragraph"},{"level":2,"text":"End-to-end example","anchor":"End-to-end-example","type":"heading"},{"inlineContent":[{"type":"text","text":"A search feature with debouncing, cancellation of in-flight queries, error fallback, and SwiftUI binding:"}],"type":"paragraph"},{"code":["import Flow","import FlowUI","","@Observable","@MainActor","final class SearchViewModel {","    private let repository: ProductRepository","    private let query = MutableStateFlow(\"\")","    let results: any StateFlow<SearchState>","","    init(repository: ProductRepository) {","        self.repository = repository","        self.results = query.asFlow()","            .debounce(for: .milliseconds(300))","            .removeDuplicates()","            .flatMapLatest { query -> ThrowingFlow<[Product]> in","                query.isEmpty ? .empty : repository.search(query)","            }","            .map { SearchState.loaded($0) }","            .catch { _, collector in","                await collector.emit(.error(\"Search failed\"))","            }","            .asStateFlow(initialValue: .idle, strategy: .whileSubscribed(stopTimeout: .seconds(5)))","    }","","    func update(query text: String) async {","        await query.send(text)","    }","}","","struct SearchView: View {","    @Bindable var viewModel: SearchViewModel","    @CollectedState(viewModel.results) var state: SearchState = .idle","    @State private var query = \"\"","","    var body: some View {","        VStack {","            TextField(\"Search\", text: $query)","                .onChange(of: query) { _, new in","                    Task { await viewModel.update(query: new) }","                }","            switch state {","            case .idle: ContentUnavailableView(\"Start typing\", systemImage: \"magnifyingglass\")","            case .loaded(let products): List(products) { ProductRow(product: $0) }","            case .error(let message): Text(message).foregroundStyle(.red)","            }","        }","    }","}"],"syntax":"swift","type":"codeListing"},{"inlineContent":[{"type":"text","text":"Every piece, from cold "},{"type":"codeVoice","code":"FlowCore\/Flow"},{"type":"text","text":" composition, debouncing, and error handling to hot "},{"type":"codeVoice","code":"FlowHotStreams\/StateFlow"},{"type":"text","text":" sharing and SwiftUI binding, is 0.1.0-through-0.4.0 API."}],"type":"paragraph"}]}],"metadata":{"modules":[{"name":"Flow"}],"role":"collection","symbolKind":"module","externalID":"Flow","title":"Flow","roleHeading":"Framework"},"kind":"symbol","references":{"doc://Flow/documentation/Flow/CancellationSemantics":{"role":"article","identifier":"doc:\/\/Flow\/documentation\/Flow\/CancellationSemantics","abstract":[{"type":"text","text":"How cancellation flows from "},{"type":"codeVoice","code":"FlowCore\/FlowScope"},{"type":"text","text":" through Swift Tasks into flow bodies, and what goes wrong when you bypass the chain."}],"type":"topic","kind":"article","title":"Cancellation Semantics","url":"\/documentation\/flow\/cancellationsemantics"},"doc://Flow/documentation/Flow/KotlinFlowMigration":{"identifier":"doc:\/\/Flow\/documentation\/Flow\/KotlinFlowMigration","url":"\/documentation\/flow\/kotlinflowmigration","type":"topic","role":"article","abstract":[{"type":"text","text":"A complete mapping from Kotlin Flow APIs to their FlowKit equivalents, with side-by-side code comparisons for the most common patterns."}],"title":"Kotlin Flow to FlowKit Migration Guide","kind":"article"},"doc://Flow/documentation/Flow":{"role":"collection","identifier":"doc:\/\/Flow\/documentation\/Flow","abstract":[{"type":"text","text":"Kotlin Flow semantics in Swift, built on Swift 6.3 strict concurrency."}],"type":"topic","kind":"symbol","title":"Flow","url":"\/documentation\/flow"},"doc://Flow/documentation/Flow/HotVsColdStreams":{"role":"article","identifier":"doc:\/\/Flow\/documentation\/Flow\/HotVsColdStreams","abstract":[{"type":"text","text":"Cold streams run once per collector. Hot streams share a single execution across all collectors. Choosing the right kind prevents duplicate network requests, dropped events, and stale state."}],"type":"topic","kind":"article","title":"Hot vs Cold Streams","url":"\/documentation\/flow\/hotvscoldstreams"},"doc://Flow/documentation/Flow/LifecycleAwareCollection":{"url":"\/documentation\/flow\/lifecycleawarecollection","kind":"article","type":"topic","title":"Lifecycle-Aware Collection","abstract":[{"type":"text","text":"Bind flow lifetimes to UI objects so collection starts when a view appears and stops automatically when it disappears."}],"identifier":"doc:\/\/Flow\/documentation\/Flow\/LifecycleAwareCollection","role":"article"},"doc://Flow/documentation/Flow/FlowVsThrowingFlow":{"role":"article","identifier":"doc:\/\/Flow\/documentation\/Flow\/FlowVsThrowingFlow","abstract":[{"type":"text","text":"A decision guide for choosing between "},{"type":"codeVoice","code":"FlowCore\/Flow"},{"type":"text","text":" and "},{"type":"codeVoice","code":"FlowCore\/ThrowingFlow"},{"type":"text","text":", and how to convert between them when your pipeline crosses the boundary."}],"type":"topic","kind":"article","title":"Flow vs ThrowingFlow","url":"\/documentation\/flow\/flowvsthrowingflow"}}}