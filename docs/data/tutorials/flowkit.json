{"identifier":{"url":"doc:\/\/Flow\/tutorials\/FlowKit","interfaceLanguage":"swift"},"metadata":{"estimatedTime":"1hr 40min","category":"FlowKit","role":"overview","categoryPathComponent":"FlowKit","title":"Meet FlowKit"},"kind":"overview","sections":[{"action":{"overridingTitleInlineContent":[{"type":"text","text":"Get started"}],"identifier":"doc:\/\/Flow\/tutorials\/Flow\/BuildingDebouncedSearch","type":"reference","isActive":true,"overridingTitle":"Get started"},"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Learn FlowKit by building real features. These tutorials walk through"},{"type":"text","text":" "},{"type":"text","text":"the patterns that come up most often: search-as-you-type, shared state"},{"type":"text","text":" "},{"type":"text","text":"across screens, wrapping callback APIs, and writing deterministic tests."}]}],"title":"Meet FlowKit","kind":"hero"},{"name":null,"image":null,"content":[],"chapters":[{"name":"Reactive UI","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Build user-facing flows with debouncing, cancellation, and shared state."}]}],"tutorials":["doc:\/\/Flow\/tutorials\/Flow\/BuildingDebouncedSearch","doc:\/\/Flow\/tutorials\/Flow\/SharingStateBetweenViews"]},{"name":"Integration","content":[{"inlineContent":[{"text":"Bridge legacy callback APIs into FlowKit and verify your pipelines.","type":"text"}],"type":"paragraph"}],"tutorials":["doc:\/\/Flow\/tutorials\/Flow\/BridgingCallbackAPI","doc:\/\/Flow\/tutorials\/Flow\/TestingFlowPipeline"]}],"kind":"volume"}],"schemaVersion":{"major":0,"patch":0,"minor":3},"variants":[{"paths":["\/tutorials\/flowkit"],"traits":[{"interfaceLanguage":"swift"}]}],"hierarchy":{"paths":[],"reference":"doc:\/\/Flow\/tutorials\/FlowKit"},"references":{"doc://Flow/tutorials/Flow/BridgingCallbackAPI":{"role":"project","identifier":"doc:\/\/Flow\/tutorials\/Flow\/BridgingCallbackAPI","estimatedTime":"25min","title":"Bridging a Callback API","kind":"project","abstract":[{"type":"text","text":"Legacy APIs such as "},{"code":"CLLocationManager","type":"codeVoice"},{"type":"text","text":", "},{"code":"AVAudioSession","type":"codeVoice"},{"type":"text","text":", and "},{"code":"URLSessionDownloadTask","type":"codeVoice"},{"type":"text","text":" deliver"},{"type":"text","text":" "},{"type":"text","text":"values through delegate methods or completion handlers rather than "},{"code":"async\/await","type":"codeVoice"},{"type":"text","text":". In this"},{"type":"text","text":" "},{"type":"text","text":"tutorial you will wrap "},{"code":"CLLocationManager","type":"codeVoice"},{"type":"text","text":"’s delegate callbacks in a "},{"code":"Flow<CLLocation>","type":"codeVoice"},{"type":"text","text":" so"},{"type":"text","text":" "},{"type":"text","text":"the rest of your app can work with a clean, cancellable stream."}],"type":"topic","url":"\/tutorials\/flow\/bridgingcallbackapi"},"doc://Flow/tutorials/FlowKit":{"type":"topic","kind":"overview","abstract":[{"type":"text","text":"Learn FlowKit by building real features. These tutorials walk through"},{"type":"text","text":" "},{"type":"text","text":"the patterns that come up most often: search-as-you-type, shared state"},{"type":"text","text":" "},{"type":"text","text":"across screens, wrapping callback APIs, and writing deterministic tests."}],"identifier":"doc:\/\/Flow\/tutorials\/FlowKit","title":"Meet FlowKit","url":"\/tutorials\/flowkit","role":"overview"},"doc://Flow/tutorials/Flow/BuildingDebouncedSearch":{"role":"project","identifier":"doc:\/\/Flow\/tutorials\/Flow\/BuildingDebouncedSearch","estimatedTime":"25min","title":"Building a Debounced Search","kind":"project","abstract":[{"type":"text","text":"Search-as-you-type is a great user experience, but firing a network"},{"type":"text","text":" "},{"type":"text","text":"request on every keystroke wastes bandwidth and hammers your server."},{"type":"text","text":" "},{"type":"text","text":"A debounced pipeline collapses rapid keystrokes into a single request"},{"type":"text","text":" "},{"type":"text","text":"that fires only after the user pauses. FlowKit makes this a four-operator"},{"type":"text","text":" "},{"type":"text","text":"chain: "},{"code":"MutableStateFlow","type":"codeVoice"},{"type":"text","text":" → "},{"code":"debounce","type":"codeVoice"},{"type":"text","text":" → "},{"code":"removeDuplicates","type":"codeVoice"},{"type":"text","text":" →"},{"type":"text","text":" "},{"code":"flatMapLatest","type":"codeVoice"},{"type":"text","text":" → "},{"code":"catch","type":"codeVoice"},{"type":"text","text":"."}],"type":"topic","url":"\/tutorials\/flow\/buildingdebouncedsearch"},"doc://Flow/tutorials/Flow/SharingStateBetweenViews":{"type":"topic","kind":"project","abstract":[{"type":"text","text":"Authentication state is the classic cross-cutting concern: the home"},{"type":"text","text":" "},{"type":"text","text":"tab, the profile screen, and a UIKit sign-in controller all need to"},{"type":"text","text":" "},{"type":"text","text":"react when the user signs in or out. Traditional approaches like singletons"},{"type":"text","text":" "},{"type":"text","text":"with delegates, "},{"code":"NotificationCenter","type":"codeVoice"},{"type":"text","text":", or a global "},{"code":"@EnvironmentObject","type":"codeVoice"},{"type":"text","text":" "},{"type":"text","text":"require manual wiring. A "},{"code":"MutableStateFlow","type":"codeVoice"},{"type":"text","text":" turns the session into"},{"type":"text","text":" "},{"type":"text","text":"a reactive stream every layer of your app can observe independently."}],"estimatedTime":"20min","identifier":"doc:\/\/Flow\/tutorials\/Flow\/SharingStateBetweenViews","title":"Sharing State Between Views","url":"\/tutorials\/flow\/sharingstatebetweenviews","role":"project"},"doc://Flow/tutorials/Flow/TestingFlowPipeline":{"role":"project","identifier":"doc:\/\/Flow\/tutorials\/Flow\/TestingFlowPipeline","estimatedTime":"30min","title":"Testing a Flow Pipeline","kind":"project","abstract":[{"type":"text","text":"Real sleeps make tests slow and flaky. FlowKit ships a "},{"type":"codeVoice","code":"TestClock"},{"type":"text","text":", a manually-advanced"},{"type":"text","text":" "},{"type":"text","text":"virtual clock, and a suite of "},{"type":"codeVoice","code":"FlowTester"},{"type":"text","text":" helpers that let you assert on stream values"},{"type":"text","text":" "},{"type":"text","text":"without waiting for wall time."}],"type":"topic","url":"\/tutorials\/flow\/testingflowpipeline"}}}